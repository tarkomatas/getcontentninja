---
import BaseLayout from '../layouts/BaseLayout.astro';
import { homeFor } from '../i18n/routes';

// Önálló, publikus kampány-oldal: márkás fejléc + teljes-képernyős Fillout-űrlap.
// A jelentkezéseket a Fillout kezeli (nincs saját DB / űrlaplogika nálunk).
const locale = 'hu';
const page = 'onlineDemo';
const home = homeFor(locale);

const title = 'Online konzultációra jelentkezés | Content Ninja';
const description =
  'Jelentkezz díjmentes online konzultációra a Content Ninjáról – töltsd ki a rövid űrlapot, és foglalj időpontot pár kattintással.';

const FILLOUT_ID = 'kma4FdWbMrus';
---

<BaseLayout
  locale={locale}
  page={page}
  title={title}
  description={description}
  noindex
  bodyClass="bg-light text-body font-display antialiased h-screen flex flex-col overflow-hidden"
>
  <!-- Márkás fejléc: logó (bal) · cím (közép) · Főoldal gomb (jobb) -->
  <header class="shrink-0 bg-card border-b border-border shadow-card">
    <div
      class="max-w-[1200px] mx-auto px-4 md:px-10 py-3 grid grid-cols-[1fr_auto_1fr] items-center gap-3"
    >
      <a href={home} class="justify-self-start shrink-0" aria-label="Content Ninja – főoldal">
        <img
          src="/assets/logo.webp"
          alt="Content Ninja"
          class="h-10 md:h-12 w-auto object-contain"
        />
      </a>

      <h1
        class="hidden md:block justify-self-center text-lg font-bold text-dark text-center whitespace-nowrap"
      >
        Online konzultációra jelentkezés
      </h1>

      <a
        href={home}
        class="cta-secondary justify-self-end items-center gap-2 px-4 py-2 text-sm"
      >
        <span class="material-symbols-outlined text-[16px]">home</span>
        <span class="hidden sm:inline">Főoldal</span>
      </a>
    </div>
  </header>

  <!-- Beágyazott Fillout-űrlap: kitölti a fejléc alatt maradó helyet -->
  <main class="flex-1 min-h-0">
    <div
      style="width:100%;height:100%"
      data-fillout-id={FILLOUT_ID}
      data-fillout-embed-type="standard"
      data-fillout-inherit-parameters
    >
    </div>
  </main>

  <!-- Fillout embed-script (Astro is:inline = Next.js next/script megfelelője) -->
  <script is:inline async src="https://server.fillout.com/embed/v1/"></script>
</BaseLayout>
