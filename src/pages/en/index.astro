---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const locale = 'en';
const page = 'home';

const title = 'Content Ninja – AI Content Creation for Webshops | Automatic Posting';
const description =
  'Content Ninja is an AI-powered content creation tool for webshops. It automatically generates posts, images and videos from your products, and publishes them for you too. Try it free!';
const keywords =
  'Content Ninja, AI content creation, webshop marketing, automatic posting, social media automation, AI influencer, content calendar';

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is Content Ninja?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Content Ninja is an AI-powered content creation and publishing platform built specifically for webshops. It automatically generates social media posts, images and videos from your products, and then publishes them on Facebook, Instagram and LinkedIn.',
      },
    },
    {
      '@type': 'Question',
      name: 'How much does a Content Ninja subscription cost?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The standard subscription is 24.990 Ft + VAT per month, which includes 400 renewing AI credits each month. The 12.495 Ft + VAT demo bonus applies only to the first month; after that the fixed price of 24.990 Ft + VAT / month applies.',
      },
    },
    {
      '@type': 'Question',
      name: 'Do I need marketing knowledge to use Content Ninja?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No, Content Ninja was made exactly for those who do not have the time or background knowledge for marketing management. The AI does the experts\' work automatically.',
      },
    },
  ],
};
---

<BaseLayout locale={locale} page={page} title={title} description={description} keywords={keywords}>
  <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(faqLd)} />

  <Header locale={locale} page={page} />

