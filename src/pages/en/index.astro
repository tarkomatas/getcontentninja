---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const locale = 'en';
const page = 'home';

const title = 'Content Ninja – AI Content Creation for Webshops | Posting & Newsletters';
const description =
  'Content Ninja is an AI-powered content creation tool for webshops. It automatically generates posts, images and videos from your products and publishes them – and it writes, designs and sends your newsletters for you too. Try it free!';
const keywords =
  'Content Ninja, AI content creation, webshop marketing, automatic posting, AI newsletter, email marketing, social media automation, AI influencer, content calendar';

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is Content Ninja?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Content Ninja is an AI-powered content creation and publishing platform built specifically for webshops. It automatically generates social media posts, images and videos from your products, and then publishes them on Facebook and Instagram – and it also writes, designs and automatically sends your newsletters from your MailerLite or Salesautopilot account.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can Content Ninja send newsletters too?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Alongside posting, Content Ninja includes a full AI newsletter module: the AI writes the copy, designs the layout, adds images, and then automatically sends it to your existing lists from your connected MailerLite or Salesautopilot account – whether a single email or an entire campaign series, with recurring or season-start automations.',
      },
    },
    {
      '@type': 'Question',
      name: 'How much does a Content Ninja subscription cost?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The standard subscription is 24.990 Ft + VAT per month, which includes 400 renewing AI credits each month. The 12.495 Ft + VAT demo bonus applies only to the first month; after that the fixed price of 24.990 Ft + VAT / month applies.',
      },
    },
    {
      '@type': 'Question',
      name: 'Do I need marketing knowledge to use Content Ninja?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No, Content Ninja was made exactly for those who do not have the time or background knowledge for marketing management. The AI does the experts\' work automatically.',
      },
    },
  ],
};
---

<BaseLayout locale={locale} page={page} title={title} description={description} keywords={keywords} lpEnabled>
  <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(faqLd)} />

  <Header locale={locale} page={page} />

  <main>
    <!-- ═══════════════════════════════════════
     HERO
═══════════════════════════════════════ -->
    <section id="hero" class="hero-gradient py-12 md:py-24 px-4 md:px-10 overflow-hidden">
        <div class="max-w-[1200px] mx-auto">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

                <!-- Left: szöveg -->
                <div class="flex flex-col gap-5 animate-fade-up">
                    <h1
                        class="text-4xl md:text-[2.85rem] lg:text-5xl font-extrabold leading-[1.08] tracking-[-0.03em] text-dark">
                        AI marketing system <span class="text-primary">for webshops</span>
                    </h1>

                    <p class="text-lg text-body leading-snug max-w-[520px]">
                        From your products, the AI writes the copy, edits the images,
                        <strong class="text-dark">generates the videos</strong> and posts – and it writes, designs
                        and sends your <strong class="text-dark">newsletters</strong>, automatically.
                    </p>

                    <ul class="space-y-2 text-body">
                        <li class="flex items-start gap-2.5">
                            <span class="material-symbols-outlined text-primary text-[20px] mt-0.5"
                                style="font-variation-settings:'FILL' 1">check_circle</span>
                            <span><strong class="text-dark">No more spending hours</strong> writing posts and
                                editing images</span>
                        </li>
                        <li class="flex items-start gap-2.5">
                            <span class="material-symbols-outlined text-primary text-[20px] mt-0.5"
                                style="font-variation-settings:'FILL' 1">check_circle</span>
                            <span><strong class="text-dark">A consistent, professional presence</strong> on social media
                                and in the inbox – even when you have no time for it</span>
                        </li>
                        <li class="flex items-start gap-2.5">
                            <span class="material-symbols-outlined text-primary text-[20px] mt-0.5"
                                style="font-variation-settings:'FILL' 1">check_circle</span>
                            <span>More visitors and buyers, <strong class="text-dark">with fewer work
                                    hours spent</strong></span>
                        </li>
                    </ul>

                    <div class="flex flex-col sm:flex-row gap-3 pt-1">
                        <a href="/en/book-demo" class="cta-primary px-7 py-4 text-base">
                            <span class="material-symbols-outlined text-[18px]">calendar_month</span>
                            Request a free demo
                        </a>
                        <a href="https://app.getcontentninja.com" target="_blank" class="cta-secondary px-7 py-4 text-base">
                            <span class="material-symbols-outlined text-[18px]">login</span>
                            Log in to the app
                        </a>
                    </div>

                    <!-- Social proof (moved to the left) -->
                    <div class="flex items-center gap-3">
                        <div class="flex -space-x-2">
                            <div
                                class="w-8 h-8 rounded-full bg-primary flex items-center justify-center text-white text-xs font-bold border-2 border-white">
                                Sz</div>
                            <div
                                class="w-8 h-8 rounded-full bg-primary/70 flex items-center justify-center text-white text-xs font-bold border-2 border-white">
                                L</div>
                            <div
                                class="w-8 h-8 rounded-full bg-primary/50 flex items-center justify-center text-white text-xs font-bold border-2 border-white">
                                ÁK</div>
                        </div>
                        <p class="text-sm text-muted"><span class="font-semibold text-dark">50+ webshops</span> already
                            use it</p>
                    </div>

                </div>

                <!-- Right: software illustration -->
                <div class="animate-fade-up delay-200">
                    <div
                        class="relative rounded-[20px] overflow-hidden shadow-primary-glow border border-primary/10 bg-light aspect-square">
                        <img src="/assets/hero-illusztracio.webp" width="1024" height="1024"
                            alt="Content Ninja turns your webshop's products into social media posts (Facebook, Instagram) and newsletters automatically"
                            class="w-full h-full object-cover" />
                    </div>
                </div>
            </div>
        </div>
    </section>


    <!-- ═══════════════════════════════════════
     USE CASES / SOLUTIONS
═══════════════════════════════════════ -->
    <section id="megoldasok" class="bg-light py-20 md:py-28 px-4 md:px-10">
        <div class="max-w-[1200px] mx-auto">
            <div class="text-center max-w-[700px] mx-auto mb-14">
                <span class="text-primary font-bold text-sm uppercase tracking-widest block mb-3">Solutions</span>
                <h2 class="text-3xl md:text-4xl font-bold mb-4">What do people use Content Ninja for?</h2>
                <p class="text-body text-lg">Pick your situation – we'll show you how the system helps.</p>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-[1200px] mx-auto">

                <!-- Automated posting -->
                <a href="/en/demo"
                    class="group bg-card rounded-[16px] border border-border p-8 shadow-card hover:shadow-card-hover transition-all hover:-translate-y-0.5 flex flex-col">
                    <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center text-primary mb-5">
                        <span class="material-symbols-outlined text-[22px]">auto_awesome</span>
                    </div>
                    <h3 class="font-bold text-xl mb-2 text-dark">Automated posting</h3>
                    <p class="text-body text-sm leading-relaxed mb-5 flex-1">The AI writes copy, creates images and videos
                        from your products, then schedules and publishes them for you – to Facebook and
                        Instagram. You just have to approve it, if you want to.</p>
                    <span class="text-primary font-bold text-sm inline-flex items-center gap-1">
                        Take a look
                        <span class="material-symbols-outlined text-[18px] group-hover:translate-x-0.5 transition-transform">arrow_forward</span>
                    </span>
                </a>

                <!-- AI newsletter -->
                <a href="/en/newsletter"
                    class="group bg-card rounded-[16px] border border-border p-8 shadow-card hover:shadow-card-hover transition-all hover:-translate-y-0.5 flex flex-col">
                    <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center text-primary mb-5">
                        <span class="material-symbols-outlined text-[22px]">mail</span>
                    </div>
                    <h3 class="font-bold text-xl mb-2 text-dark">AI newsletters</h3>
                    <p class="text-body text-sm leading-relaxed mb-5 flex-1">The AI writes, designs and fills your
                        newsletters with images, then sends them automatically from your MailerLite or Salesautopilot
                        account – even a whole campaign series.</p>
                    <span class="text-primary font-bold text-sm inline-flex items-center gap-1">
                        Learn more
                        <span class="material-symbols-outlined text-[18px] group-hover:translate-x-0.5 transition-transform">arrow_forward</span>
                    </span>
                </a>

                <!-- International expansion -->
                <a href="/en/international"
                    class="group bg-card rounded-[16px] border border-border p-8 shadow-card hover:shadow-card-hover transition-all hover:-translate-y-0.5 flex flex-col">
                    <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center text-primary mb-5">
                        <span class="material-symbols-outlined text-[22px]">public</span>
                    </div>
                    <h3 class="font-bold text-xl mb-2 text-dark">International expansion</h3>
                    <p class="text-body text-sm leading-relaxed mb-5 flex-1">Multiple countries, multiple languages? Every
                        language version from one piece of content, every country's accounts in one calendar.</p>
                    <span class="text-primary font-bold text-sm inline-flex items-center gap-1">
                        Learn more
                        <span class="material-symbols-outlined text-[18px] group-hover:translate-x-0.5 transition-transform">arrow_forward</span>
                    </span>
                </a>

                <!-- UNAS integration -->
                <a href="/en/unas"
                    class="group bg-card rounded-[16px] border border-border p-8 shadow-card hover:shadow-card-hover transition-all hover:-translate-y-0.5 flex flex-col">
                    <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center text-primary mb-5">
                        <span class="material-symbols-outlined text-[22px]">storefront</span>
                    </div>
                    <h3 class="font-bold text-xl mb-2 text-dark">UNAS integration</h3>
                    <p class="text-body text-sm leading-relaxed mb-5 flex-1">Connect your UNAS webshop in a few clicks –
                        from then on the AI sees all your products and only creates posts from your top, in-stock items.</p>
                    <span class="text-primary font-bold text-sm inline-flex items-center gap-1">
                        Learn more
                        <span class="material-symbols-outlined text-[18px] group-hover:translate-x-0.5 transition-transform">arrow_forward</span>
                    </span>
                </a>

            </div>
        </div>
    </section>


    <!-- ═══════════════════════════════════════
     HOGYAN MŰKÖDIK
═══════════════════════════════════════ -->
    <section id="hogyan-mukodik" class="bg-card py-20 md:py-28 px-4 md:px-10">
        <div class="max-w-[1200px] mx-auto">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">

                <!-- Left: square illustration -->
                <div class="relative order-1">
                    <div class="absolute inset-0 bg-primary/10 blur-3xl rounded-full -z-10"></div>
                    <img src="/assets/hogyan-mukodik.webp" width="1024" height="1024"
                        alt="Content Ninja's self-running workflow shown as a loop: initial setup, idea hunting, content generation, then publishing and newsletter sending"
                        loading="lazy" class="w-full h-auto block max-w-[460px] mx-auto" />
                </div>

                <!-- Right: short copy -->
                <div class="order-2">
                    <span class="text-primary font-bold text-sm uppercase tracking-widest block mb-3">How does it work?</span>
                    <h2 class="text-3xl md:text-4xl font-bold mb-4 leading-tight">4 steps to full automation</h2>
                    <p class="text-body mb-8 leading-relaxed">You set it up once, and the AI handles the rest on its own.</p>

                    <ul class="space-y-5 mb-8">
                        <li class="flex items-start gap-4">
                            <div class="w-9 h-9 rounded-full bg-primary text-white font-extrabold flex items-center justify-center shrink-0 shadow-primary-glow">1</div>
                            <p class="text-body pt-1"><strong class="text-dark">Initial setup.</strong> You provide your webshop link and logo.</p>
                        </li>
                        <li class="flex items-start gap-4">
                            <div class="w-9 h-9 rounded-full bg-primary text-white font-extrabold flex items-center justify-center shrink-0 shadow-primary-glow">2</div>
                            <p class="text-body pt-1"><strong class="text-dark">Hunts for ideas.</strong> It reviews your shop and picks products and topics.</p>
                        </li>
                        <li class="flex items-start gap-4">
                            <div class="w-9 h-9 rounded-full bg-primary text-white font-extrabold flex items-center justify-center shrink-0 shadow-primary-glow">3</div>
                            <p class="text-body pt-1"><strong class="text-dark">Generates content.</strong> Post copy or a newsletter – with images, video, on-brand.</p>
                        </li>
                        <li class="flex items-start gap-4">
                            <div class="w-9 h-9 rounded-full bg-primary text-white font-extrabold flex items-center justify-center shrink-0 shadow-primary-glow">4</div>
                            <p class="text-body pt-1"><strong class="text-dark">Publishes and sends.</strong> The AI <span class="text-primary font-semibold">posts it and sends it as a newsletter</span> for you.</p>
                        </li>
                    </ul>

                    <a href="/en/book-demo" class="cta-primary px-8 py-4 text-base">
                        Request a demo – free
                    </a>
                </div>

            </div>
        </div>
    </section>


    <!-- ═══════════════════════════════════════
     INTEGRATIONS
═══════════════════════════════════════ -->
    <section id="integraciok" class="bg-light py-20 md:py-28 px-4 md:px-10">
        <div class="max-w-[1200px] mx-auto">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">

                <!-- Text + categories -->
                <div class="order-2 lg:order-1">
                    <span class="text-primary font-bold text-sm uppercase tracking-widest block mb-3">Integrations</span>
                    <h2 class="text-3xl md:text-4xl font-bold mb-3 leading-tight">Connect what you already have – it posts
                        where you need it</h2>
                    <p class="text-body mb-6 leading-relaxed">Content Ninja connects your webshop, your sources
                        and your social accounts: it pulls in your products and content, generates the posts and
                        newsletters, and publishes them too – automatically.</p>

                    <ul class="space-y-3 mb-6">
                        <li class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary shrink-0">
                                <span class="material-symbols-outlined text-[20px]">share</span>
                            </div>
                            <div>
                                <p class="font-semibold text-dark text-[15px] leading-tight">Social media</p>
                                <p class="text-body text-sm">Facebook, Instagram</p>
                            </div>
                        </li>
                        <li class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary shrink-0">
                                <span class="material-symbols-outlined text-[20px]">storefront</span>
                            </div>
                            <div>
                                <p class="font-semibold text-dark text-[15px] leading-tight">Webshop</p>
                                <p class="text-body text-sm">Unas, Sitemap <span class="text-muted">(any webshop)</span></p>
                            </div>
                        </li>
                        <li class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary shrink-0">
                                <span class="material-symbols-outlined text-[20px]">mail</span>
                            </div>
                            <div>
                                <p class="font-semibold text-dark text-[15px] leading-tight">Newsletter</p>
                                <p class="text-body text-sm">SalesAutopilot, MailerLite</p>
                            </div>
                        </li>
                        <li class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary shrink-0">
                                <span class="material-symbols-outlined text-[20px]">rss_feed</span>
                            </div>
                            <div>
                                <p class="font-semibold text-dark text-[15px] leading-tight">External sites</p>
                                <p class="text-body text-sm">RSS</p>
                            </div>
                        </li>
                    </ul>

                    <!-- Any link highlight -->
                    <div class="rounded-[14px] border border-primary/25 bg-primary/[0.04] p-4 flex items-start gap-3 mb-6">
                        <span class="material-symbols-outlined text-primary text-[22px] shrink-0 mt-0.5">link</span>
                        <p class="text-body text-sm leading-relaxed"><strong class="text-dark">+ From any external or
                            internal link too</strong> – it also turns a product link, blog article or external page
                            into a ready-to-go post.</p>
                    </div>

                    <a href="/en/book-demo" class="cta-primary px-8 py-4 text-base">
                        Request a demo – free
                    </a>
                </div>

                <!-- Illustration: integration hub -->
                <div class="order-1 lg:order-2 relative">
                    <div class="absolute inset-0 bg-primary/10 blur-3xl rounded-full -z-10"></div>
                    <img src="/assets/integraciok-hub.webp"
                        alt="Content Ninja integration hub: Unas, Sitemap and RSS sources connected, then publishing to Facebook, Instagram, SalesAutopilot and MailerLite"
                        loading="lazy" class="w-full h-auto block">
                </div>

            </div>
        </div>
    </section>


    <!-- ═══════════════════════════════════════
     VÉLEMÉNYEK
═══════════════════════════════════════ -->
    <section id="velemenyek" class="bg-card py-20 md:py-28 px-4 md:px-10">
        <div class="max-w-[1200px] mx-auto">
            <div class="text-center max-w-[700px] mx-auto mb-14">
                <span class="text-primary font-bold text-sm uppercase tracking-widest block mb-3">Reviews</span>
                <h2 class="text-3xl md:text-4xl font-bold mb-4">What do our customers say about us?</h2>
            </div>

            <div class="relative">
                <button type="button" id="ti-prev"
                    class="hidden sm:flex absolute left-3 top-1/2 -translate-y-1/2 xl:-left-6 z-10 w-11 h-11 items-center justify-center rounded-full bg-card border border-border text-primary shadow-card hover:shadow-card-hover hover:border-primary transition-all"
                    aria-label="Previous review">
                    <span class="material-symbols-outlined text-[24px]">chevron_left</span>
                </button>
                <button type="button" id="ti-next"
                    class="hidden sm:flex absolute right-3 top-1/2 -translate-y-1/2 xl:-right-6 z-10 w-11 h-11 items-center justify-center rounded-full bg-card border border-border text-primary shadow-card hover:shadow-card-hover hover:border-primary transition-all"
                    aria-label="Next review">
                    <span class="material-symbols-outlined text-[24px]">chevron_right</span>
                </button>
                <div class="overflow-hidden" id="ti-viewport">
                    <div class="flex" style="gap:2rem" id="ti-track">

                        <!-- T1 -->
                        <div class="ti-card flex flex-col bg-light p-5 sm:p-8 rounded-[16px] border border-border shadow-card hover:shadow-card-hover transition-all"
                            style="flex-shrink:0">
                            <div class="mb-4">
                                <span class="material-symbols-outlined text-primary/10 text-[56px]"
                                    style="font-variation-settings:'FILL' 1">format_quote</span>
                            </div>
                            <div class="flex gap-0.5 mb-4 -mt-2">
                                <span class="text-yellow-400">★</span><span class="text-yellow-400">★</span><span
                                    class="text-yellow-400">★</span><span class="text-yellow-400">★</span><span
                                    class="text-yellow-400">★</span>
                            </div>
                            <p class="text-body italic mb-6 leading-relaxed flex-1">„It saves a huge amount of time by
                                generating text and images on its own from a product link and posting automatically too. A big
                                help!"</p>
                            <div class="flex items-center gap-3 mt-auto">
                                <div
                                    class="w-11 h-11 rounded-full bg-primary flex items-center justify-center text-white font-bold text-sm uppercase">
                                    Sz</div>
                                <div>
                                    <p class="font-bold text-dark text-sm">Szabad Mária</p>
                                    <p class="text-xs text-muted">Károlyi-plast online store</p>
                                </div>
                            </div>
                        </div>

                        <!-- T2 -->
                        <div class="ti-card flex flex-col bg-light p-5 sm:p-8 rounded-[16px] border border-border shadow-card hover:shadow-card-hover transition-all"
                            style="flex-shrink:0">
                            <div class="mb-4">
                                <span class="material-symbols-outlined text-primary/10 text-[56px]"
                                    style="font-variation-settings:'FILL' 1">format_quote</span>
                            </div>
                            <div class="flex gap-0.5 mb-4 -mt-2">
                                <span class="text-yellow-400">★</span><span class="text-yellow-400">★</span><span
                                    class="text-yellow-400">★</span><span class="text-yellow-400">★</span><span
                                    class="text-yellow-400">★</span>
                            </div>
                            <p class="text-body italic mb-6 leading-relaxed flex-1">„I have little time for marketing, but
                                with this I can still post regularly. It generates content in bulk, suggests topics on its
                                own too, and its video features keep getting better. A serious time saver."</p>
                            <div class="flex items-center gap-3 mt-auto">
                                <div
                                    class="w-11 h-11 rounded-full bg-primary/70 flex items-center justify-center text-white font-bold text-sm uppercase">
                                    L</div>
                                <div>
                                    <p class="font-bold text-dark text-sm">Luca Márió</p>
                                    <p class="text-xs text-muted">PanDani.hu toy store and webshop</p>
                                </div>
                            </div>
                        </div>

                        <!-- T3 -->
                        <div class="ti-card flex flex-col bg-light p-5 sm:p-8 rounded-[16px] border border-border shadow-card hover:shadow-card-hover transition-all"
                            style="flex-shrink:0">
                            <div class="mb-4">
                                <span class="material-symbols-outlined text-primary/10 text-[56px]"
                                    style="font-variation-settings:'FILL' 1">format_quote</span>
                            </div>
                            <div class="flex gap-0.5 mb-4 -mt-2">
                                <span class="text-yellow-400">★</span><span class="text-yellow-400">★</span><span
                                    class="text-yellow-400">★</span><span class="text-yellow-400">★</span><span
                                    class="text-yellow-400">★</span>
                            </div>
                            <p class="text-body italic mb-6 leading-relaxed flex-1">„I really like it! At last I can see the
                                light at the end of the tunnel, so I'll have posts compared to the nothing I had before :)
                                In a word, brilliant! And I had been looking for a tool for my problem, but couldn't find one
                                like this..."</p>
                            <div class="flex items-center gap-3 mt-auto">
                                <div
                                    class="w-11 h-11 rounded-full bg-primary/50 flex items-center justify-center text-white font-bold text-sm uppercase">
                                    ÁK</div>
                                <div>
                                    <p class="font-bold text-dark text-sm">Ábrahám Kata</p>
                                    <p class="text-xs text-muted">Yoga Bazaar online store</p>
                                </div>
                            </div>
                        </div>

                        <!-- T4 -->
                        <div class="ti-card flex flex-col bg-light p-5 sm:p-8 rounded-[16px] border border-border shadow-card hover:shadow-card-hover transition-all"
                            style="flex-shrink:0">
                            <div class="mb-4">
                                <span class="material-symbols-outlined text-primary/10 text-[56px]"
                                    style="font-variation-settings:'FILL' 1">format_quote</span>
                            </div>
                            <div class="flex gap-0.5 mb-4 -mt-2">
                                <span class="text-yellow-400">★</span><span class="text-yellow-400">★</span><span
                                    class="text-yellow-400">★</span><span class="text-yellow-400">★</span><span
                                    class="text-yellow-400">★</span>
                            </div>
