    <script is:inline>
                (function () {
                    var track = document.getElementById('t-track');
                    var viewport = document.getElementById('t-viewport');
                    var dotsContainer = document.getElementById('t-dots');
                    var prevButton = document.getElementById('t-prev');
                    var nextButton = document.getElementById('t-next');
                    var cards = track.querySelectorAll('.t-card');
                    var GAP = 32;
                    var current = 0;
                    var autoTimer;

                    function getVisible() {
                        return window.innerWidth >= 1024 ? 3 : window.innerWidth >= 640 ? 2 : 1;
                    }

                    function getTotal() {
                        return Math.max(1, cards.length - getVisible() + 1);
                    }

                    function buildDots() {
                        dotsContainer.innerHTML = '';
                        var total = getTotal();
                        for (var i = 0; i < total; i++) {
                            (function (idx) {
                                var btn = document.createElement('button');
                                btn.style.cssText = 'border:none;cursor:pointer;border-radius:9999px;transition:all 0.3s;height:10px;';
                                btn.style.background = idx === current ? '#6c5ce7' : 'rgba(108,92,231,0.3)';
                                btn.style.width = idx === current ? '24px' : '10px';
                                btn.addEventListener('click', function () { goTo(idx); resetTimer(); });
                                dotsContainer.appendChild(btn);
                            })(i);
                        }
                    }

                    function layout() {
                        var vis = getVisible();
                        var vw = viewport.offsetWidth;
                        var cw = (vw - GAP * (vis - 1)) / vis;
                        for (var i = 0; i < cards.length; i++) {
                            cards[i].style.width = cw + 'px';
                        }
                        current = Math.min(current, getTotal() - 1);
                        buildDots();
                        goTo(current, false);
                    }

                    function goTo(index, animate) {
                        if (animate === undefined) animate = true;
                        current = Math.max(0, Math.min(index, getTotal() - 1));
                        var cw = parseFloat(cards[0].style.width);
                        var offset = current * (cw + GAP);
                        track.style.transition = animate ? 'transform 0.5s cubic-bezier(0.25,0.46,0.45,0.94)' : 'none';
                        track.style.transform = 'translateX(-' + offset + 'px)';
                        buildDots();
                    }

                    function next() {
                        goTo(current + 1 < getTotal() ? current + 1 : 0);
                    }

                    function prev() {
                        goTo(current - 1 >= 0 ? current - 1 : getTotal() - 1);
                    }

                    function resetTimer() {
                        clearInterval(autoTimer);
                        autoTimer = setInterval(next, 5000);
                    }

                    layout();
                    resetTimer();

                    var resizeTimer;
                    window.addEventListener('resize', function () {
                        clearTimeout(resizeTimer);
                        resizeTimer = setTimeout(layout, 100);
                    });

                    prevButton.addEventListener('click', function () { prev(); resetTimer(); });
                    nextButton.addEventListener('click', function () { next(); resetTimer(); });
                    viewport.addEventListener('mouseenter', function () { clearInterval(autoTimer); });
                    viewport.addEventListener('mouseleave', resetTimer);
                })();
    </script>

