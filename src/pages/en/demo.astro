    <script is:inline>
        function nextStep(step) {
            // Hide all steps
            const steps = document.querySelectorAll('.form-step');
            steps.forEach(s => s.classList.remove('active'));

            const formIntro = document.getElementById('formIntro');
            const hideIntroSteps = ['rejected', 'soft-reject', 'soft-reject-thanks'];
            if (formIntro) {
                formIntro.classList.toggle('hidden', hideIntroSteps.includes(String(step)));
            }

            // Show requested step
            const activeStep = document.querySelector(`.form-step[data-step="${step}"]`);
            if (activeStep) {
                activeStep.classList.add('active');
            }
        }

        // Store qualifying data for use in soft reject submission
        let _qualifyData = {};

        function qualifyAndNext() {
            const webshop = document.getElementById('hasWebshop').value;
            const level = document.getElementById('marketingLevel').value;
            const role = document.getElementById('marketingRole').value;
            const timing = document.getElementById('timing').value;

            // Validate that all four are selected
            if (!webshop || !level || !role || !timing) {
                alert('Please answer every question!');
                return;
            }

            // Store for later use
            _qualifyData = { webshop, level, role, timing };

            // Hard disqualify: no webshop OR agency handling posts OR no marketing knowledge
            const isHardRejected =
                webshop === 'Nem, más típusú vállalkozásom van' ||
                level === 'Egyáltalán nem értünk semmit a témához' ||
                role === 'Külsős ügynökség';

            // Soft reject: no webshop yet OR timing not ideal (but otherwise OK)
            const isSoftRejected =
                webshop === 'Igen, hamarosan tervezek nyitni' ||
                timing === '2-3 hónapon belül' ||
                timing === 'Még csak érdeklődöm';

            if (isHardRejected) {
                nextStep('rejected');

                fetch('https://hook.eu1.make.com/ihohtlulor66lvhouyoty9azbut7lzx7', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        statusz: 'hard_reject',
                        submission_date: new Date().toISOString(),
                        has_webshop: webshop,
                        marketing_level: level,
                        marketing_role: role,
                        timing: timing,
                        source_url: window.location.href
                    })
                }).catch(() => { });

            } else if (isSoftRejected) {
                nextStep('soft-reject');

            } else {
                nextStep(2);
            }
        }

        async function submitSoftReject() {
            const email = document.getElementById('softRejectEmail').value.trim();
            if (!email || !email.includes('@')) {
                alert('Please enter a valid email address!');
                return;
            }

            const privacy = document.getElementById('softRejectPrivacy');
            if (!privacy.checked) {
                alert('Please accept the privacy policy!');
                return;
            }

            const newsletterChecked = document.getElementById('softRejectNewsletter').checked;

            const btn = event.target;
            btn.innerHTML = 'Sending...';
            btn.disabled = true;

            const payload = {
                submission_date: new Date().toISOString(),
                email: email,
                hirlevel_feliratkozas: newsletterChecked ? 'Igen' : 'Nem',
                has_webshop: _qualifyData.webshop || '',
                marketing_level: _qualifyData.level || '',
                marketing_role: _qualifyData.role || '',
                timing: _qualifyData.timing || '',
                source_url: window.location.href
            };

            try {
                await fetch('https://hook.eu1.make.com/ihohtlulor66lvhouyoty9azbut7lzx7', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ ...payload, statusz: 'soft_reject' })
                });
            } catch (e) { }

            nextStep('soft-reject-thanks');
        }

        document.addEventListener('DOMContentLoaded', function () {
            const submitBtn = document.getElementById('submitBtn');
            const FORM_SUBMITTED_KEY = 'ai_tartalomgyartas_form_submitted';

            // Check if form was already submitted in this session
            if (sessionStorage.getItem(FORM_SUBMITTED_KEY) === 'true') {
                submitBtn.disabled = true;
                submitBtn.innerHTML = 'Already submitted';
                submitBtn.classList.add('opacity-50', 'cursor-not-allowed');
            }

            // Handle Form Submit via Webhook to Make.com
            document.getElementById('leadForm').addEventListener('submit', async function (e) {
                e.preventDefault();

                // Double-check: prevent duplicate submissions
                if (sessionStorage.getItem(FORM_SUBMITTED_KEY) === 'true') {
                    console.log('Form already submitted, preventing duplicate.');
                    return;
                }

                const privacy = document.getElementById('privacy');
                if (!privacy.checked) {
                    alert("Please accept the privacy policy!");
                    return;
                }

                const btn = document.getElementById('submitBtn');
                const originalText = btn.innerHTML;
                btn.innerHTML = 'Sending...';
                btn.disabled = true;

                // Mark as submitted IMMEDIATELY to prevent race conditions
                sessionStorage.setItem(FORM_SUBMITTED_KEY, 'true');

                const formData = new FormData(this);

                // Collect clean form data
                const cleanData = {};
                formData.forEach((value, key) => {
                    // Handle checkbox arrays (like usage[])
                    if (cleanData[key]) {
                        if (!Array.isArray(cleanData[key])) {
                            cleanData[key] = [cleanData[key]];
                        }
                        cleanData[key].push(value);
                    } else {
                        cleanData[key] = value;
                    }
