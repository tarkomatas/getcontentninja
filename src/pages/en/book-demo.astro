---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';

const locale = 'en';
const page = 'bookDemo';
const title = 'Book a Demo – AI marketing for webshops | Content Ninja';
const description =
  'Request a free, ~20-minute online demo of Content Ninja and see live how AI creates and publishes your social media content, and how it writes, designs and sends your newsletters – all from your own products.';
---

<BaseLayout locale={locale} page={page} title={title} description={description} lpEnabled>
  <Fragment slot="head">
    <style is:inline>
        *,
        *::before,
        *::after {
            box-sizing: border-box;
        }

        html {
            margin: 0;
            padding: 0;
            background-color: #ffffff;
        }

        body {
            margin: 0;
            background-color: #f8f9fb;
            color: #4a4a68;
            letter-spacing: -0.01em;
        }

        h1,
        h2,
        h3,
        h4,
        h5,
        h6 {
            color: #1e1e2f;
            letter-spacing: -0.02em;
            font-weight: 700;
        }

        .cta-primary {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            background-color: #6c5ce7;
            color: white;
            font-weight: 600;
            padding: 14px 28px;
            border-radius: 10px;
            border: none;
            transition: background 0.2s ease;
            text-decoration: none;
            white-space: nowrap;
            line-height: 1.2;
        }

        .cta-primary:hover {
            background-color: #5a4bd6;
        }

        .cta-secondary {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            background-color: transparent;
            border: 1.5px solid #6c5ce7;
            color: #6c5ce7;
            padding: 14px 28px;
            border-radius: 10px;
            transition: background 0.2s ease;
            font-weight: 600;
            text-decoration: none;
            white-space: nowrap;
            line-height: 1.2;
        }

        .cta-secondary:hover {
            background-color: rgba(108, 92, 231, 0.08);
        }

        .cta-primary .material-symbols-outlined,
        .cta-secondary .material-symbols-outlined {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 1em;
            height: 1em;
            line-height: 1;
            flex-shrink: 0;
        }

        .custom-scrollbar::-webkit-scrollbar {
            width: 6px;
        }

        .custom-scrollbar::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 4px;
        }

        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #d1d5db;
            border-radius: 4px;
        }

        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: #9ca3af;
        }

        .form-step {
            display: none;
            animation: fadeIn 0.4s ease-out;
        }

        .form-step.active {
            display: block;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .hero-gradient {
            background: linear-gradient(135deg, #f0eeff 0%, #f8f9fb 60%, #eef6ff 100%);
        }

        .hero-form-card {
            background: linear-gradient(180deg, #ffffff 0%, #fbfaff 100%);
            border: 1.5px solid rgba(108, 92, 231, 0.24);
            box-shadow: 0 18px 55px rgba(30, 30, 47, 0.12), 0 0 0 6px rgba(108, 92, 231, 0.06);
        }

        .hero-form-card:hover {
            border-color: rgba(108, 92, 231, 0.36);
            box-shadow: 0 22px 65px rgba(30, 30, 47, 0.15), 0 0 0 6px rgba(108, 92, 231, 0.08);
        }
    </style>
  </Fragment>

  <div class="relative flex min-h-screen w-full flex-col">
    <!-- Közös fejléc – ?type=ld (lp-mode) esetén minimálra vált (logó + nyelvváltó) -->
    <Header locale={locale} page={page} />

    <!-- 1. Hero + booking form -->
    <section id="hero" class="hero-gradient py-12 md:py-24 px-4 md:px-10 overflow-hidden">
        <div class="max-w-[1200px] mx-auto w-full">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 md:gap-12 lg:gap-20 items-center">

                <!-- Content -->
                <div class="flex flex-col gap-4 md:gap-7 text-left">

                    <span class="inline-flex items-center gap-2 self-start bg-primary/10 text-primary text-xs font-bold uppercase tracking-widest px-3 py-1.5 rounded-full">
                        <span class="material-symbols-outlined text-[16px]">calendar_month</span>
                        Free online demo
                    </span>

                    <h1 class="text-4xl md:text-[2.85rem] lg:text-5xl font-extrabold leading-[1.08] tracking-[-0.03em] text-dark">
                        See live how the AI <span class="text-primary">posts and sends newsletters</span> for your webshop
                    </h1>
                    <p class="text-body text-[1.1rem] font-medium leading-relaxed max-w-[520px]">
                        In a ~20-minute online demo we'll show you the system in action –
                        <span class="font-bold text-primary">with your own products</span> and your own examples.
                    </p>

                    <ul class="space-y-3.5 text-body">
                        <li class="flex items-start gap-2.5">
                            <span class="material-symbols-outlined text-primary text-[20px] mt-0.5" style="font-variation-settings:'FILL' 1">check_circle</span>
                            <span><strong>Automated posting</strong> to Facebook and Instagram</span>
                        </li>
                        <li class="flex items-start gap-2.5">
                            <span class="material-symbols-outlined text-primary text-[20px] mt-0.5" style="font-variation-settings:'FILL' 1">check_circle</span>
                            <span><strong>AI newsletters</strong> – written, designed, sent</span>
                        </li>
                        <li class="flex items-start gap-2.5">
                            <span class="material-symbols-outlined text-primary text-[20px] mt-0.5" style="font-variation-settings:'FILL' 1">check_circle</span>
                            <span>One system for your <strong>entire webshop marketing</strong></span>
                        </li>
                    </ul>

                    <!-- Social proof mini -->
                    <div class="flex items-center gap-3">
                        <div class="flex -space-x-2">
                            <div class="w-8 h-8 rounded-full bg-primary flex items-center justify-center text-white text-xs font-bold border-2 border-white">Sz</div>
                            <div class="w-8 h-8 rounded-full bg-primary/70 flex items-center justify-center text-white text-xs font-bold border-2 border-white">L</div>
                            <div class="w-8 h-8 rounded-full bg-primary/50 flex items-center justify-center text-white text-xs font-bold border-2 border-white">ÁK</div>
                        </div>
                        <p class="text-sm text-muted"><span class="font-semibold text-dark">50+ webshops</span> already use it</p>
                    </div>

                </div>

                <!-- Form Container -->
                <div class="w-full relative">
                    <div class="hero-form-card relative w-full rounded-[16px] transition-all py-6 px-4 md:py-8 md:px-5">
                        <div id="formIntro">
                            <h3 class="text-2xl font-bold text-center mb-2 text-primary">Book an online demo</h3>
                            <div class="flex items-center gap-2.5 justify-center bg-light border border-primary/15 rounded-[10px] px-4 py-3 mb-3">
                                <span class="material-symbols-outlined text-primary text-[20px] shrink-0">info</span>
                                <p class="text-sm text-body"><strong class="font-bold text-dark">There's no direct
                                    self-trial</strong> – but in an online meeting we'll walk you through the system in
                                    detail, even with your own products and newsletters.</p>
                            </div>
                        </div>

                        <form id="leadForm" class="space-y-4 max-h-[500px] overflow-hidden pr-2 custom-scrollbar relative">

                            <!-- Step 1: Qualifying Questions -->
                            <div class="form-step active" data-step="1">
                                <div class="space-y-4">
                                    <div>
                                        <label class="block text-sm font-bold text-body mb-1">Do you have a webshop /
                                            online store?</label>
                                        <select name="has_webshop" id="hasWebshop"
                                            class="w-full rounded-[10px] border-border focus:border-primary focus:ring-primary shadow-card hover:shadow-card-hover transition-all">
                                            <option value="" disabled selected>Choose...</option>
                                            <option value="Yes, I have a webshop">Yes, I have a webshop</option>
                                            <option value="Yes, planning to launch soon">Yes, planning to launch
                                                soon</option>
                                            <option value="No, I run a different type of business">No, I run a different
                                                type of business</option>
                                        </select>
                                    </div>
                                    <div>
                                        <label class="block text-sm font-bold text-body mb-1">How advanced is your
                                            company in marketing?</label>
                                        <select name="marketing_level" id="marketingLevel"
                                            class="w-full rounded-[10px] border-border focus:border-primary focus:ring-primary shadow-card hover:shadow-card-hover transition-all">
                                            <option value="" disabled selected>Choose...</option>
                                            <option value="We know nothing about the topic">We know nothing about the
                                                topic</option>
                                            <option value="Beginner, minimal knowledge">Beginner, minimal
                                                knowledge</option>
                                            <option value="Intermediate">Intermediate</option>
                                            <option value="Pro">Pro</option>
                                        </select>
                                    </div>
                                    <div>
                                        <label class="block text-sm font-bold text-body mb-1">Who currently handles your
                                            marketing?</label>
                                        <select name="marketing_role" id="marketingRole"
                                            class="w-full rounded-[10px] border-border focus:border-primary focus:ring-primary shadow-card hover:shadow-card-hover transition-all">
                                            <option value="" disabled selected>Choose...</option>
                                            <option value="Me, as the business owner">Me, as the business owner</option>
                                            <option value="In-house marketing team">In-house marketing team</option>
                                            <option value="External agency">External agency</option>
                                        </select>
                                    </div>
                                    <div>
                                        <label class="block text-sm font-bold text-body mb-1">If you like what you see in
                                            the demo, when could you start using the software?</label>
                                        <select name="timing" id="timing"
                                            class="w-full rounded-[10px] border-border focus:border-primary focus:ring-primary shadow-card hover:shadow-card-hover transition-all">
                                            <option value="" disabled selected>Choose...</option>
                                            <option value="Right away">Right away</option>
                                            <option value="Within 1 month">Within 1 month</option>
                                            <option value="Within 2-3 months">Within 2-3 months</option>
                                            <option value="Just exploring for now">Just exploring for now</option>
                                        </select>
                                    </div>
                                    <button type="button" onclick="qualifyAndNext()"
                                        class="w-full mt-4 flex items-center justify-center rounded-[10px] h-12 cta-primary transition-all hover:brightness-95 transition-all">
                                        Continue
                                    </button>
                                </div>
                            </div>

                            <!-- Disqualification Screen (hard reject) -->
                            <div class="form-step" data-step="rejected">
                                <div class="text-center py-6 space-y-4">
                                    <h4 class="text-xl font-bold text-dark">Thanks for your interest!</h4>
                                    <p class="text-body leading-relaxed max-w-[400px] mx-auto">
                                        Based on your answers, it looks like our platform wouldn't be the right fit for
                                        you. We don't want to take up your time – thank you for understanding!
                                    </p>
                                </div>
                            </div>

                            <!-- Soft Reject Screen (timing not ideal) -->
                            <div class="form-step" data-step="soft-reject">
                                <div class="space-y-5">
                                    <div class="text-center space-y-3">
                                        <h4 class="text-xl font-bold text-dark">Thanks for your interest!</h4>
                                        <p class="text-body leading-relaxed text-sm">
                                            We can only offer demos to people who want to start using the system right
                                            away. Let's stay in touch in the meantime – we'd be happy to send you a
                                            <strong>video walkthrough</strong>.
                                        </p>
                                    </div>
                                    <div>
                                        <label class="block text-sm font-bold text-body mb-1">Email address</label>
                                        <input type="email" id="softRejectEmail"
                                            class="w-full rounded-[10px] border-border focus:border-primary focus:ring-primary shadow-card hover:shadow-card-hover transition-all"
                                            placeholder="e.g. john@company.com">
                                    </div>
                                    <div class="flex items-start gap-2 text-xs text-muted ml-1">
                                        <input type="checkbox" id="softRejectPrivacy"
                                            class="mt-1 rounded text-primary focus:ring-primary">
                                        <label for="softRejectPrivacy">
                                            I have read, understood and accepted the
                                            <a href="/en/privacy-policy" target="_blank"
                                                class="underline hover:text-primary">Privacy Policy</a>.
                                        </label>
                                    </div>
                                    <div class="flex items-start gap-2 text-xs text-muted ml-1">
                                        <input type="checkbox" id="softRejectNewsletter"
                                            class="mt-1 rounded text-primary focus:ring-primary">
                                        <label for="softRejectNewsletter">
                                            I'm interested in more content like this! Subscribe me to the newsletter.
                                            (<a href="/en/privacy-policy"
                                                class="underline hover:text-primary">Privacy Policy</a>)
                                        </label>
                                    </div>
                                    <button type="button" onclick="submitSoftReject()"
                                        class="w-full flex items-center justify-center rounded-[10px] h-12 cta-primary transition-all hover:brightness-95">
                                        Send me the video
                                    </button>
                                </div>
                            </div>

                            <!-- Soft Reject Thank You Screen -->
                            <div class="form-step" data-step="soft-reject-thanks">
                                <div class="text-center py-6 space-y-4">
                                    <div class="w-16 h-16 bg-success/10 rounded-full flex items-center justify-center mx-auto">
                                        <span class="material-symbols-outlined text-success text-3xl">check_circle</span>
                                    </div>
                                    <h4 class="text-xl font-bold text-dark">Got it!</h4>
                                    <p class="text-body leading-relaxed max-w-[400px] mx-auto">
                                        We'll send over the demo video and the latest updates shortly. Thanks for your
                                        interest!
                                    </p>
                                </div>
                            </div>

                            <!-- Step 2: Contact Info & Privacy -->
                            <div class="form-step" data-step="2">
                                <div class="space-y-4">
                                    <div>
                                        <label class="block text-sm font-bold text-body mb-1">Name</label>
                                        <input type="text" name="name" required
                                            class="w-full rounded-[10px] border-border focus:border-primary focus:ring-primary shadow-card hover:shadow-card-hover transition-all"
                                            placeholder="e.g. John Smith">
                                    </div>
                                    <div>
                                        <label class="block text-sm font-bold text-body mb-1">Company email</label>
                                        <input type="email" name="email" required
                                            class="w-full rounded-[10px] border-border focus:border-primary focus:ring-primary shadow-card hover:shadow-card-hover transition-all"
                                            placeholder="e.g. john@company.com">
                                    </div>
                                    <div>
                                        <label class="block text-sm font-bold text-body mb-1">Phone number</label>
                                        <input type="tel" name="phone" required
                                            class="w-full rounded-[10px] border-border focus:border-primary focus:ring-primary shadow-card hover:shadow-card-hover transition-all"
                                            placeholder="+1 555 123 4567">
                                    </div>

                                    <div class="flex items-start gap-2 text-xs text-muted my-2 ml-1">
                                        <input type="checkbox" id="privacy" required
                                            class="mt-1 rounded text-primary focus:ring-primary">
                                        <label for="privacy">
                                            I have read, understood and accepted the
                                            <a href="/en/privacy-policy" target="_blank"
                                                class="underline hover:text-primary">Privacy Policy</a>.
                                        </label>
                                    </div>

                                    <div class="flex items-start gap-2 text-xs text-muted my-2 ml-1">
                                        <input type="checkbox" id="newsletter" name="newsletter"
                                            class="mt-1 rounded text-primary focus:ring-primary">
                                        <label for="newsletter">
                                            I'm interested in more content like this! Subscribe me to the newsletter.
                                            (<a href="/en/privacy-policy"
                                                class="underline hover:text-primary">Privacy Policy</a>)
                                        </label>
                                    </div>

                                    <div class="flex gap-3 mt-4">
                                        <button type="button" onclick="nextStep(1)"
                                            class="flex-shrink-0 hidden md:flex items-center justify-center rounded-[10px] h-12 px-4 border-2 border-border text-body text-base font-bold hover:bg-light transition-all">
                                            <span class="material-symbols-outlined text-base mr-1">arrow_back</span>
                                            Back
                                        </button>
                                        <button type="submit" id="submitBtn"
                                            class="flex-1 flex items-center justify-center rounded-[10px] h-12 cta-primary transition-all hover:brightness-95 transition-all">
                                            Continue to booking!
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- 2. What we'll show you in the demo -->
    <section class="bg-card py-20 md:py-28 px-4 md:px-10">
        <div class="max-w-[1200px] mx-auto">
            <div class="text-center max-w-[700px] mx-auto mb-12">
                <h2 class="text-3xl md:text-4xl font-bold mb-4">What we'll show you in the demo</h2>
                <p class="text-body text-lg">Not just posting – we walk through your entire webshop marketing, with your
                    own products.</p>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                <div class="bg-light rounded-[16px] border border-border p-8 shadow-card hover:shadow-card-hover transition-all hover:-translate-y-0.5">
                    <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center text-primary mb-5">
                        <span class="material-symbols-outlined text-[22px]">send</span>
                    </div>
                    <h3 class="font-bold text-lg mb-2">Automated posting</h3>
                    <p class="text-body text-sm leading-relaxed">The AI writes copy, creates images and video from your
                        products, then posts on schedule to Facebook and Instagram.</p>
                </div>

                <div class="bg-light rounded-[16px] border border-border p-8 shadow-card hover:shadow-card-hover transition-all hover:-translate-y-0.5">
                    <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center text-primary mb-5">
                        <span class="material-symbols-outlined text-[22px]">mail</span>
                    </div>
                    <h3 class="font-bold text-lg mb-2">AI newsletters</h3>
                    <p class="text-body text-sm leading-relaxed">Writes, designs and fills your newsletters with images,
                        then sends them from your MailerLite or Salesautopilot account.</p>
                </div>

                <div class="bg-light rounded-[16px] border border-border p-8 shadow-card hover:shadow-card-hover transition-all hover:-translate-y-0.5">
                    <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center text-primary mb-5">
                        <span class="material-symbols-outlined text-[22px]">movie_filter</span>
                    </div>
                    <h3 class="font-bold text-lg mb-2">Image & video generation</h3>
                    <p class="text-body text-sm leading-relaxed">On-brand, logoed creatives and motion videos from your
                        existing product photos – no studio needed.</p>
                </div>

                <div class="bg-light rounded-[16px] border border-border p-8 shadow-card hover:shadow-card-hover transition-all hover:-translate-y-0.5">
                    <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center text-primary mb-5">
                        <span class="material-symbols-outlined text-[22px]">schedule_send</span>
                    </div>
                    <h3 class="font-bold text-lg mb-2">Full automation</h3>
                    <p class="text-body text-sm leading-relaxed">Set it up once, then the system creates and publishes
                        content week after week on its own – you don't even have to check in.</p>
                </div>
            </div>

            <div class="text-center mt-12">
                <a href="#hero" class="cta-primary px-8 py-4 text-base">
                    <span class="material-symbols-outlined text-[18px]">calendar_month</span>
                    Book a free demo
                </a>
            </div>
        </div>
    </section>

    <!-- 3. Testimonials (short, static) -->
    <section class="bg-light py-20 md:py-28 px-4 md:px-10">
        <div class="max-w-[1200px] mx-auto">
            <div class="text-center max-w-[700px] mx-auto mb-12">
                <h2 class="text-3xl md:text-4xl font-bold mb-4">What our customers say</h2>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
                <div class="flex flex-col bg-card p-8 rounded-[16px] border border-border shadow-card">
                    <div class="flex gap-0.5 mb-4">
                        <span class="text-yellow-400">★</span><span class="text-yellow-400">★</span><span
                            class="text-yellow-400">★</span><span class="text-yellow-400">★</span><span
                            class="text-yellow-400">★</span>
                    </div>
                    <p class="text-body italic mb-6 leading-relaxed flex-1">„It saves a huge amount of time by generating
                        copy and images from a product link and posting automatically. A big help!"</p>
                    <div class="flex items-center gap-3 mt-auto">
                        <div class="w-11 h-11 rounded-full bg-primary flex items-center justify-center text-white font-bold text-sm uppercase">Sz</div>
                        <div>
                            <p class="font-bold text-dark text-sm">Mária Szabad</p>
                            <p class="text-xs text-muted">Károlyi-plast webshop</p>
                        </div>
                    </div>
                </div>

                <div class="flex flex-col bg-card p-8 rounded-[16px] border border-border shadow-card">
                    <div class="flex gap-0.5 mb-4">
                        <span class="text-yellow-400">★</span><span class="text-yellow-400">★</span><span
                            class="text-yellow-400">★</span><span class="text-yellow-400">★</span><span
                            class="text-yellow-400">★</span>
                    </div>
                    <p class="text-body italic mb-6 leading-relaxed flex-1">„I have little time for marketing, yet I can
                        still post regularly with this. It generates content in bulk, suggests topics on its own, and the
                        video features keep getting better. A serious time-saver."</p>
                    <div class="flex items-center gap-3 mt-auto">
                        <div class="w-11 h-11 rounded-full bg-primary/70 flex items-center justify-center text-white font-bold text-sm uppercase">L</div>
                        <div>
                            <p class="font-bold text-dark text-sm">Márió Luca</p>
                            <p class="text-xs text-muted">PanDani.hu toy store & webshop</p>
                        </div>
                    </div>
                </div>

                <div class="flex flex-col bg-card p-8 rounded-[16px] border border-border shadow-card">
                    <div class="flex gap-0.5 mb-4">
                        <span class="text-yellow-400">★</span><span class="text-yellow-400">★</span><span
                            class="text-yellow-400">★</span><span class="text-yellow-400">★</span><span
                            class="text-yellow-400">★</span>
                    </div>
                    <p class="text-body italic mb-6 leading-relaxed flex-1">„I really like it! I finally see the light at
                        the end of the tunnel – I'll have posts compared to nothing before :) In a word, brilliant! I'd
                        searched for a tool for my problem but couldn't find one like this..."</p>
                    <div class="flex items-center gap-3 mt-auto">
                        <div class="w-11 h-11 rounded-full bg-primary/50 flex items-center justify-center text-white font-bold text-sm uppercase">ÁK</div>
                        <div>
                            <p class="font-bold text-dark text-sm">Kata Ábrahám</p>
                            <p class="text-xs text-muted">Yoga Bazaar webshop</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="py-12 bg-dark text-muted text-sm border-t border-dark/90">
        <div class="max-w-[1200px] mx-auto px-4 md:px-10">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-8">
                <div>
                    <div class="bg-white p-3 rounded-xl inline-block mb-4"><img src="/assets/logo.webp" alt="Logo"
                            class="h-8 md:h-10"></div>
                    <p class="text-muted">A system that creates marketing content on behalf of your webshop, on
                        autopilot.</p>
                </div>
                <div>
                    <h4 class="text-white font-bold mb-4">Legal</h4>
                    <ul class="space-y-2">
                        <li><a href="/en/privacy-policy" class="hover:text-white">Privacy policy</a></li>
                        <li><a href="/en/imprint" class="hover:text-white">Imprint</a></li>
                        <li><a href="/en/terms" class="hover:text-white">Terms of Service</a></li>
                    </ul>
                </div>
            </div>
            <div class="border-t border-border pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
                <p>Copyright © contentninja.hu | 2026</p>
            </div>
        </div>
    </footer>

    <script is:inline>
        function nextStep(step) {
            const steps = document.querySelectorAll('.form-step');
            steps.forEach(s => s.classList.remove('active'));

            const formIntro = document.getElementById('formIntro');
            const hideIntroSteps = ['rejected', 'soft-reject', 'soft-reject-thanks'];
            if (formIntro) {
                formIntro.classList.toggle('hidden', hideIntroSteps.includes(String(step)));
            }

            const activeStep = document.querySelector(`.form-step[data-step="${step}"]`);
            if (activeStep) {
                activeStep.classList.add('active');
            }
        }

        let _qualifyData = {};

        function qualifyAndNext() {
            const webshop = document.getElementById('hasWebshop').value;
            const level = document.getElementById('marketingLevel').value;
            const role = document.getElementById('marketingRole').value;
            const timing = document.getElementById('timing').value;

            if (!webshop || !level || !role || !timing) {
                alert('Please answer every question!');
                return;
            }

            _qualifyData = { webshop, level, role, timing };

            const isHardRejected =
                webshop === 'No, I run a different type of business' ||
                level === 'We know nothing about the topic' ||
                role === 'External agency';

            const isSoftRejected =
                webshop === 'Yes, planning to launch soon' ||
                timing === 'Within 2-3 months' ||
                timing === 'Just exploring for now';

            if (isHardRejected) {
                nextStep('rejected');

                fetch('https://hook.eu1.make.com/ihohtlulor66lvhouyoty9azbut7lzx7', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        statusz: 'hard_reject',
                        lead_forras: 'online-bemutato',
                        submission_date: new Date().toISOString(),
                        has_webshop: webshop,
                        marketing_level: level,
                        marketing_role: role,
                        timing: timing,
                        source_url: window.location.href
                    })
                }).catch(() => { });

            } else if (isSoftRejected) {
                nextStep('soft-reject');

            } else {
                nextStep(2);
            }
        }

        async function submitSoftReject() {
            const email = document.getElementById('softRejectEmail').value.trim();
            if (!email || !email.includes('@')) {
                alert('Please enter a valid email address!');
                return;
            }

            const privacy = document.getElementById('softRejectPrivacy');
            if (!privacy.checked) {
                alert('Please accept the privacy policy!');
                return;
            }

            const newsletterChecked = document.getElementById('softRejectNewsletter').checked;

            const btn = event.target;
            btn.innerHTML = 'Sending...';
            btn.disabled = true;

            const payload = {
                submission_date: new Date().toISOString(),
                lead_forras: 'online-bemutato',
                email: email,
                hirlevel_feliratkozas: newsletterChecked ? 'Igen' : 'Nem',
                has_webshop: _qualifyData.webshop || '',
                marketing_level: _qualifyData.level || '',
                marketing_role: _qualifyData.role || '',
                timing: _qualifyData.timing || '',
                source_url: window.location.href
            };

            try {
                await fetch('https://hook.eu1.make.com/ihohtlulor66lvhouyoty9azbut7lzx7', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ ...payload, statusz: 'soft_reject' })
                });
            } catch (e) { }

            nextStep('soft-reject-thanks');
        }

        document.addEventListener('DOMContentLoaded', function () {
            const submitBtn = document.getElementById('submitBtn');
            const FORM_SUBMITTED_KEY = 'online_bemutato_form_submitted';

            if (sessionStorage.getItem(FORM_SUBMITTED_KEY) === 'true') {
                submitBtn.disabled = true;
                submitBtn.innerHTML = 'Already submitted';
                submitBtn.classList.add('opacity-50', 'cursor-not-allowed');
            }

            document.getElementById('leadForm').addEventListener('submit', async function (e) {
                e.preventDefault();

                if (sessionStorage.getItem(FORM_SUBMITTED_KEY) === 'true') {
                    console.log('Form already submitted, preventing duplicate.');
                    return;
                }

                const privacy = document.getElementById('privacy');
                if (!privacy.checked) {
                    alert("Please accept the privacy policy!");
                    return;
                }

                const btn = document.getElementById('submitBtn');
                btn.innerHTML = 'Sending...';
                btn.disabled = true;

                sessionStorage.setItem(FORM_SUBMITTED_KEY, 'true');

                const formData = new FormData(this);
                const cleanData = {};
                formData.forEach((value, key) => {
                    if (cleanData[key]) {
                        if (!Array.isArray(cleanData[key])) {
                            cleanData[key] = [cleanData[key]];
                        }
                        cleanData[key].push(value);
                    } else {
                        cleanData[key] = value;
                    }
                });

                cleanData['source_url'] = window.location.href;
                const customSubject = `🚀 Demo request: ${cleanData['name']}`;
                cleanData['subject'] = customSubject;

                const newsletterChecked = document.getElementById('newsletter').checked;
                const webhookPayload = {
                    statusz: 'sikeres',
                    lead_forras: 'online-bemutato',
                    submission_date: new Date().toISOString(),
                    nev: cleanData['name'],
                    email: cleanData['email'],
                    telefonszam: cleanData['phone'],
                    source_url: window.location.href,
                    has_webshop: cleanData['has_webshop'],
                    marketing_level: cleanData['marketing_level'],
                    marketing_role: cleanData['marketing_role'],
                    timing: cleanData['timing'],
                    hirlevel_feliratkozas: newsletterChecked ? 'Igen' : 'Nem'
                };

                try {
                    const result = await fetch('https://hook.eu1.make.com/ihohtlulor66lvhouyoty9azbut7lzx7', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(webhookPayload)
                    });
                    console.log('Webhook sent:', result.ok);
                    window.location.href = "/en/thank-you?lead=1";
                } catch (error) {
                    console.error('Unexpected error:', error);
                    window.location.href = "/en/thank-you?lead=1";
                }
            });
        });
    </script>
  </div>
</BaseLayout>
