---
import BaseLayout from '../../layouts/BaseLayout.astro';

const locale = 'en';
const page = 'thanks';
const title = 'Thank you! – Content Ninja';
const description = 'Thank you for your submission! The next step is to book a free online demo slot.';
---

<BaseLayout
  locale={locale}
  page={page}
  title={title}
  description={description}
  noindex={true}
  bodyClass="bg-card text-dark font-display antialiased min-h-screen flex flex-col"
>
  <!-- Header (focused – logo only) -->
  <header class="border-b border-solid border-b-border bg-card sticky top-0 z-50 transition-all">
    <div class="max-w-[1200px] mx-auto px-4 md:px-10 py-4 flex items-center justify-between whitespace-nowrap">
      <div class="flex items-center gap-3 text-dark">
        <a href="/en/">
          <img src="/assets/logo.webp" alt="Content Ninja logo" class="h-14 md:h-16 w-auto object-contain" />
        </a>
      </div>
    </div>
  </header>

  <!-- Main Content -->
  <main class="flex-1 flex flex-col items-center justify-center py-10 px-4">
    <div class="w-full max-w-[1200px]">
      <!-- Unified Card -->
      <div class="bg-card rounded-[16px] border border-border shadow-card overflow-hidden">
        <!-- Card Header -->
        <div class="px-8 md:px-14 pt-10 pb-8 border-b border-border">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <!-- Center: main title -->
            <div class="flex items-center gap-4">
              <div class="w-11 h-11 rounded-full bg-primary/10 flex items-center justify-center text-primary shrink-0">
                <span class="material-symbols-outlined text-[22px]">calendar_month</span>
              </div>
              <div>
                <h1 class="text-2xl md:text-3xl font-bold text-dark tracking-[-0.02em] leading-tight">
                  Pick an available time slot
                </h1>
                <p class="text-muted text-sm mt-0.5">Online demo – free, approx. 20 minutes</p>
              </div>
            </div>

            <!-- Right: success badge -->
            <div class="flex items-center gap-2.5 bg-success/10 border border-success/20 rounded-[10px] px-4 py-2.5 shrink-0 self-start sm:self-auto">
              <span class="material-symbols-outlined text-success text-[18px]" style="font-variation-settings:'FILL' 1">check_circle</span>
              <div>
                <p class="font-semibold text-dark text-sm leading-tight">Thanks for filling it out!</p>
                <p class="text-body text-xs mt-0.5">The next step is to book a time slot.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Calendar Embed -->
        <div class="px-2 md:px-4 py-4">
          <div
            style="width:100%;min-height:600px;"
            data-fillout-id="3FdjMXSLMuus"
            data-fillout-embed-type="standard"
            data-fillout-inherit-parameters
            data-fillout-dynamic-resize
          >
          </div>
          <script is:inline src="https://server.fillout.com/embed/v1/"></script>
        </div>
      </div>
    </div>
  </main>

  <!-- Footer (focused) -->
  <footer class="py-8 text-center text-muted text-sm border-t border-border bg-card mt-4">
    <p>Copyright © contentninja.hu | 2026</p>
  </footer>

  <!-- Lead tracking: the Facebook 'Lead' event fires only when ?lead=1 is present -->
  <script is:inline>
    (function () {
      const urlParams = new URLSearchParams(window.location.search);
      const isLead = urlParams.get("lead") === "1";
      if (!isLead) return;

      let leadTracked = false;
      let attempts = 0;
      const maxAttempts = 40; // 40 * 500ms = max 20s wait

      function trackLead() {
        if (leadTracked) return true;
        attempts++;
        if (typeof fbq === 'function') {
          try {
            fbq('track', 'Lead');
            leadTracked = true;
            return true;
          } catch (e) {
            console.error("Pixel tracking error:", e);
          }
        }
        if (attempts >= maxAttempts) return true;
        return false;
      }

      if (!trackLead()) {
        const checkInterval = setInterval(() => {
          if (trackLead()) clearInterval(checkInterval);
        }, 500);
      }
    })();
  </script>
</BaseLayout>
