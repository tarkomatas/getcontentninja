---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const locale = 'hu';
const page = 'home';

const title = 'Content Ninja – AI Tartalomgyártás Webshopoknak | Posztolás és Hírlevélküldés';
const description =
  'A Content Ninja AI-alapú tartalomgyártó eszköz webshopoknak. Automatikusan generál posztokat, képeket és videókat a termékeidből és publikálja is – sőt, hírleveleket is ír, tervez és kiküld helyetted. Próbáld ki díjmentesen!';
const keywords =
  'Content Ninja, AI tartalomgyártás, webshop marketing, automatikus posztolás, AI hírlevél, hírlevélküldés, social media automatizálás, AI influenszer, tartalomnaptár';

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Mi az a Content Ninja?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A Content Ninja egy AI-alapú tartalomgyártó és publikáló platform, amelyet kifejezetten webshopok számára fejlesztettünk. Automatikusan generál social media posztokat, képeket és videókat a termékeidből, majd ezeket Facebookon és Instagramon közzé is teszi – sőt, hírleveleket is ír, megtervez és a MailerLite vagy Salesautopilot fiókodból automatikusan ki is küld.',
      },
    },
    {
      '@type': 'Question',
      name: 'Tud a Content Ninja hírlevelet is küldeni?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Igen. A posztolás mellett a Content Ninja egy teljes AI hírlevél-modult is tartalmaz: az AI megírja a szöveget, megtervezi a dizájnt, képeket rak bele, majd a bekötött MailerLite vagy Salesautopilot fiókodból a meglévő listáidra automatikusan kiküldi – akár egyetlen levelet, akár egy egész kampánysorozatot, rendszeres vagy szezon eleji automatizmusokkal.',
      },
    },
    {
      '@type': 'Question',
      name: 'Mennyibe kerül a Content Ninja előfizetés?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A standard előfizetés havi 24.990 Ft + ÁFA, amely havi 400 megújuló AI kreditet tartalmaz. A 12.495 Ft + ÁFA bemutató bónusz csak az első hónapra szól, utána a fix 24.990 Ft + ÁFA / hó ár érvényes.',
      },
    },
    {
      '@type': 'Question',
      name: 'Kell-e marketing tudás a Content Ninja használatához?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Nem, a Content Ninja pont azoknak készült, akiknek nincs ideje vagy háttértudása a marketing menedzsmenthez. Az AI elvégzi a szakértők munkáját automatikusan.',
      },
    },
  ],
};
---

<BaseLayout locale={locale} page={page} title={title} description={description} keywords={keywords}>
  <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(faqLd)} />

  <Header locale={locale} page={page} />

  <main>
    <!-- ═══════════════════════════════════════
     HERO
═══════════════════════════════════════ -->
    <section id="hero" class="hero-gradient py-10 md:py-28 px-4 md:px-10 overflow-hidden">
        <div class="max-w-[1200px] mx-auto">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

                <!-- Left: szöveg -->
                <div class="flex flex-col gap-5 animate-fade-up">
                    <h1
                        class="text-4xl md:text-[2.85rem] lg:text-5xl font-extrabold leading-[1.08] tracking-[-0.03em] text-dark">
                        Automatizáld be<br /><span class="text-primary">webshopod</span>
                        tartalomgyártását
                    </h1>

                    <p class="text-lg text-body leading-snug max-w-[520px]">
                        A Content Ninja AI szöveget ír, képet szerkeszt,
                        <strong class="text-dark">videót generál</strong> és posztol is helyetted –
                        sőt, a <strong class="text-dark">hírleveleidet</strong> is megírja, megtervezi és kiküldi.
                        A termékeidből, automatikusan.
                    </p>

                    <ul class="space-y-2 text-body">
                        <li class="flex items-start gap-2.5">
                            <span class="material-symbols-outlined text-primary text-[20px] mt-0.5"
                                style="font-variation-settings:'FILL' 1">check_circle</span>
                            <span><strong class="text-dark">Nem kell többé órákat töltened</strong> posztok írásával és
                                képek szerkesztésével</span>
                        </li>
                        <li class="flex items-start gap-2.5">
                            <span class="material-symbols-outlined text-primary text-[20px] mt-0.5"
                                style="font-variation-settings:'FILL' 1">check_circle</span>
                            <span><strong class="text-dark">Folyamatos, profi jelenlét</strong> a social médiában és a
                                postaládákban – akkor is, ha nincs rá időd</span>
                        </li>
                        <li class="flex items-start gap-2.5">
                            <span class="material-symbols-outlined text-primary text-[20px] mt-0.5"
                                style="font-variation-settings:'FILL' 1">check_circle</span>
                            <span>Több látogató és vásárló, <strong class="text-dark">kevesebb ráfordított
                                    munkaórával</strong></span>
                        </li>
                    </ul>

                    <div class="flex flex-col sm:flex-row gap-3 pt-1">
                        <a href="/hu/online-bemutato" class="cta-primary px-7 py-4 text-base">
                            <span class="material-symbols-outlined text-[18px]">calendar_month</span>
                            Díjmentes bemutatót kérek
                        </a>
                        <a href="https://app.getcontentninja.com" target="_blank" class="cta-secondary px-7 py-4 text-base">
                            <span class="material-symbols-outlined text-[18px]">login</span>
                            Belépek az appba
                        </a>
                    </div>

                    <!-- Social proof (balra helyezve) -->
                    <div class="flex items-center gap-3">
                        <div class="flex -space-x-2">
                            <div
                                class="w-8 h-8 rounded-full bg-primary flex items-center justify-center text-white text-xs font-bold border-2 border-white">
                                Sz</div>
                            <div
                                class="w-8 h-8 rounded-full bg-primary/70 flex items-center justify-center text-white text-xs font-bold border-2 border-white">
                                L</div>
                            <div
                                class="w-8 h-8 rounded-full bg-primary/50 flex items-center justify-center text-white text-xs font-bold border-2 border-white">
                                ÁK</div>
                        </div>
                        <p class="text-sm text-muted"><span class="font-semibold text-dark">50+ webshop</span> már
                            használja</p>
                    </div>

                </div>

                <!-- Right: szoftver látványkép -->
                <div class="animate-fade-up delay-200">
                    <div
                        class="relative rounded-[20px] overflow-hidden shadow-primary-glow border border-primary/10 bg-light aspect-square">
                        <img src="/assets/hero-illusztracio.webp" width="1024" height="1024"
                            alt="A Content Ninja a webshopod termékeiből automatikusan közösségi média posztokat (Facebook, Instagram) és hírleveleket gyárt"
                            class="w-full h-full object-cover" />
                    </div>
                </div>
            </div>
        </div>
    </section>


    <!-- ═══════════════════════════════════════
     MEGOLDÁSOK / USE-CASE-EK
═══════════════════════════════════════ -->
    <section id="megoldasok" class="bg-light py-20 md:py-28 px-4 md:px-10">
        <div class="max-w-[1200px] mx-auto">
            <div class="text-center max-w-[700px] mx-auto mb-14">
                <span class="text-primary font-bold text-sm uppercase tracking-widest block mb-3">Megoldások</span>
                <h2 class="text-3xl md:text-4xl font-bold mb-4">Mire használják a Content Ninját?</h2>
                <p class="text-body text-lg">Válaszd ki, mi a te helyzeted – megmutatjuk, hogyan segít a rendszer.</p>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-[1200px] mx-auto">

                <!-- Automata posztolás -->
                <a href="/hu/posztolas"
                    class="group bg-card rounded-[16px] border border-border p-8 shadow-card hover:shadow-card-hover transition-all hover:-translate-y-0.5 flex flex-col">
                    <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center text-primary mb-5">
                        <span class="material-symbols-outlined text-[22px]">auto_awesome</span>
                    </div>
                    <h3 class="font-bold text-xl mb-2 text-dark">Automata posztolás</h3>
                    <p class="text-body text-sm leading-relaxed mb-5 flex-1">Az AI a termékeidből szöveget ír, képet és
                        videót készít, majd időzítve ki is posztolja helyetted – Facebookra és Instagramra.
                        Neked csak jóvá kell hagynod, ha szeretnéd.</p>
                    <span class="text-primary font-bold text-sm inline-flex items-center gap-1">
                        Nézd meg
                        <span class="material-symbols-outlined text-[18px] group-hover:translate-x-0.5 transition-transform">arrow_forward</span>
                    </span>
                </a>

                <!-- AI hírlevél -->
                <a href="/hu/hirlevel"
                    class="group bg-card rounded-[16px] border border-border p-8 shadow-card hover:shadow-card-hover transition-all hover:-translate-y-0.5 flex flex-col">
                    <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center text-primary mb-5">
                        <span class="material-symbols-outlined text-[22px]">mail</span>
                    </div>
                    <h3 class="font-bold text-xl mb-2 text-dark">AI hírlevél küldés</h3>
                    <p class="text-body text-sm leading-relaxed mb-5 flex-1">Az AI megírja, megtervezi és képekkel tölti
                        fel a hírleveleidet, majd a MailerLite vagy Salesautopilot fiókodból automatikusan ki is küldi –
                        akár egész kampánysorozatot.</p>
                    <span class="text-primary font-bold text-sm inline-flex items-center gap-1">
                        Részletek
                        <span class="material-symbols-outlined text-[18px] group-hover:translate-x-0.5 transition-transform">arrow_forward</span>
                    </span>
                </a>

                <!-- Nemzetközi terjeszkedés -->
                <a href="/hu/nemzetkozi"
                    class="group bg-card rounded-[16px] border border-border p-8 shadow-card hover:shadow-card-hover transition-all hover:-translate-y-0.5 flex flex-col">
                    <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center text-primary mb-5">
                        <span class="material-symbols-outlined text-[22px]">public</span>
                    </div>
                    <h3 class="font-bold text-xl mb-2 text-dark">Nemzetközi terjeszkedés</h3>
                    <p class="text-body text-sm leading-relaxed mb-5 flex-1">Több országban, több nyelven? Egy tartalomból
                        minden nyelvi verzió, minden ország közösségi fiókja egy naptárban.</p>
                    <span class="text-primary font-bold text-sm inline-flex items-center gap-1">
                        Részletek
                        <span class="material-symbols-outlined text-[18px] group-hover:translate-x-0.5 transition-transform">arrow_forward</span>
                    </span>
                </a>

                <!-- UNAS integráció -->
                <a href="/hu/unas"
                    class="group bg-card rounded-[16px] border border-border p-8 shadow-card hover:shadow-card-hover transition-all hover:-translate-y-0.5 flex flex-col">
                    <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center text-primary mb-5">
                        <span class="material-symbols-outlined text-[22px]">storefront</span>
                    </div>
                    <h3 class="font-bold text-xl mb-2 text-dark">UNAS integráció</h3>
                    <p class="text-body text-sm leading-relaxed mb-5 flex-1">Kösd be az UNAS webshopod pár kattintással –
                        az AI onnantól látja az összes terméked, és csak a top, raktáron lévő darabokból gyárt posztokat.</p>
                    <span class="text-primary font-bold text-sm inline-flex items-center gap-1">
                        Részletek
                        <span class="material-symbols-outlined text-[18px] group-hover:translate-x-0.5 transition-transform">arrow_forward</span>
                    </span>
                </a>

            </div>
        </div>
    </section>


    <!-- ═══════════════════════════════════════
     HOGYAN MŰKÖDIK
═══════════════════════════════════════ -->
    <section id="hogyan-mukodik" class="bg-card py-20 md:py-28 px-4 md:px-10">
        <div class="max-w-[1200px] mx-auto">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">

                <!-- Bal: négyzetes illusztráció -->
                <div class="relative order-1">
                    <div class="absolute inset-0 bg-primary/10 blur-3xl rounded-full -z-10"></div>
                    <img src="/assets/hogyan-mukodik.webp" width="1024" height="1024"
                        alt="A Content Ninja önjáró munkafolyamata körkörös ábrán: alapbeállítás, ötletkeresés, tartalomgyártás, majd publikálás és hírlevélküldés"
                        loading="lazy" class="w-full h-auto block max-w-[460px] mx-auto" />
                </div>

                <!-- Jobb: rövid szöveg -->
                <div class="order-2">
                    <span class="text-primary font-bold text-sm uppercase tracking-widest block mb-3">Hogyan működik?</span>
                    <h2 class="text-3xl md:text-4xl font-bold mb-4 leading-tight">4 lépés a teljes automatizálásig</h2>
                    <p class="text-body mb-8 leading-relaxed">Egyszer beállítod, az AI a többit magától intézi.</p>

                    <ul class="space-y-5 mb-8">
                        <li class="flex items-start gap-4">
                            <div class="w-9 h-9 rounded-full bg-primary text-white font-extrabold flex items-center justify-center shrink-0 shadow-primary-glow">1</div>
                            <p class="text-body pt-1"><strong class="text-dark">Alapbeállítás.</strong> Megadod a webshopod linkjét és a logódat.</p>
                        </li>
                        <li class="flex items-start gap-4">
                            <div class="w-9 h-9 rounded-full bg-primary text-white font-extrabold flex items-center justify-center shrink-0 shadow-primary-glow">2</div>
                            <p class="text-body pt-1"><strong class="text-dark">Ötletet vadászik.</strong> Átnézi a webshopod, termékeket és témákat választ.</p>
                        </li>
                        <li class="flex items-start gap-4">
                            <div class="w-9 h-9 rounded-full bg-primary text-white font-extrabold flex items-center justify-center shrink-0 shadow-primary-glow">3</div>
                            <p class="text-body pt-1"><strong class="text-dark">Tartalmat generál.</strong> Posztszöveg vagy hírlevél – képpel, videóval, márkahűen.</p>
                        </li>
                        <li class="flex items-start gap-4">
                            <div class="w-9 h-9 rounded-full bg-primary text-white font-extrabold flex items-center justify-center shrink-0 shadow-primary-glow">4</div>
                            <p class="text-body pt-1"><strong class="text-dark">Publikál és küld.</strong> Az AI <span class="text-primary font-semibold">posztolja, hírlevélben kiküldi</span> helyetted.</p>
                        </li>
                    </ul>

                    <a href="/hu/online-bemutato" class="cta-primary px-8 py-4 text-base">
                        Bemutatót kérek – díjmentes
                    </a>
                </div>

            </div>
        </div>
    </section>


    <!-- ═══════════════════════════════════════
     INTEGRÁCIÓK
═══════════════════════════════════════ -->
    <section id="integraciok" class="bg-light py-20 md:py-28 px-4 md:px-10">
        <div class="max-w-[1200px] mx-auto">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">

                <!-- Szöveg + kategóriák -->
                <div class="order-2 lg:order-1">
                    <span class="text-primary font-bold text-sm uppercase tracking-widest block mb-3">Integrációk</span>
                    <h2 class="text-3xl md:text-4xl font-bold mb-3 leading-tight">Csatlakoztasd, amid van – posztol,
                        amerre kell</h2>
                    <p class="text-body mb-6 leading-relaxed">A Content Ninja összeköti a webshopodat, a
                        forrásaidat és a közösségi fiókjaidat: behúzza a termékeidet és a tartalmaidat, legyártja a
                        posztokat és a hírleveleket, majd publikál is – automatikusan.</p>

                    <ul class="space-y-3 mb-6">
                        <li class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary shrink-0">
                                <span class="material-symbols-outlined text-[20px]">share</span>
                            </div>
                            <div>
                                <p class="font-semibold text-dark text-[15px] leading-tight">Közösségi média</p>
                                <p class="text-body text-sm">Facebook, Instagram</p>
                            </div>
                        </li>
                        <li class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary shrink-0">
                                <span class="material-symbols-outlined text-[20px]">storefront</span>
                            </div>
                            <div>
                                <p class="font-semibold text-dark text-[15px] leading-tight">Webáruház</p>
                                <p class="text-body text-sm">Unas, Sitemap <span class="text-muted">(bármely webshop)</span></p>
                            </div>
                        </li>
                        <li class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary shrink-0">
                                <span class="material-symbols-outlined text-[20px]">mail</span>
                            </div>
                            <div>
                                <p class="font-semibold text-dark text-[15px] leading-tight">Hírlevél</p>
                                <p class="text-body text-sm">SalesAutopilot, MailerLite</p>
                            </div>
                        </li>
                        <li class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary shrink-0">
                                <span class="material-symbols-outlined text-[20px]">rss_feed</span>
                            </div>
                            <div>
                                <p class="font-semibold text-dark text-[15px] leading-tight">Külsős oldalak</p>
                                <p class="text-body text-sm">RSS</p>
                            </div>
                        </li>
                    </ul>

                    <!-- Bármilyen link kiemelés -->
                    <div class="rounded-[14px] border border-primary/25 bg-primary/[0.04] p-4 flex items-start gap-3 mb-6">
                        <span class="material-symbols-outlined text-primary text-[22px] shrink-0 mt-0.5">link</span>
                        <p class="text-body text-sm leading-relaxed"><strong class="text-dark">+ Bármilyen külső vagy
                            belső linkből is</strong> – terméklink, blogcikk vagy külső oldal tartalmából is kész
                            posztot készít.</p>
                    </div>

                    <a href="/hu/online-bemutato" class="cta-primary px-8 py-4 text-base">
                        Bemutatót kérek – díjmentes
                    </a>
                </div>

                <!-- Szemléltető kép: integrációs hub -->
                <div class="order-1 lg:order-2 relative">
                    <div class="absolute inset-0 bg-primary/10 blur-3xl rounded-full -z-10"></div>
                    <img src="/assets/integraciok-hub.webp"
                        alt="Content Ninja integrációs hub: Unas, Sitemap és RSS források bekötve, majd publikálás Facebookra, Instagramra, SalesAutopilotba és MailerLite-ba"
                        loading="lazy" class="w-full h-auto block">
                </div>

            </div>
        </div>
    </section>


    <!-- ═══════════════════════════════════════
     VÉLEMÉNYEK
═══════════════════════════════════════ -->
    <section id="velemenyek" class="bg-card py-20 md:py-28 px-4 md:px-10">
        <div class="max-w-[1200px] mx-auto">
            <div class="text-center max-w-[700px] mx-auto mb-14">
                <span class="text-primary font-bold text-sm uppercase tracking-widest block mb-3">Vélemények</span>
                <h2 class="text-3xl md:text-4xl font-bold mb-4">Mit mondanak rólunk ügyfeleink?</h2>
            </div>

            <div class="relative">
                <button type="button" id="ti-prev"
                    class="hidden sm:flex absolute left-3 top-1/2 -translate-y-1/2 xl:-left-6 z-10 w-11 h-11 items-center justify-center rounded-full bg-card border border-border text-primary shadow-card hover:shadow-card-hover hover:border-primary transition-all"
                    aria-label="Előző vélemény">
                    <span class="material-symbols-outlined text-[24px]">chevron_left</span>
                </button>
                <button type="button" id="ti-next"
                    class="hidden sm:flex absolute right-3 top-1/2 -translate-y-1/2 xl:-right-6 z-10 w-11 h-11 items-center justify-center rounded-full bg-card border border-border text-primary shadow-card hover:shadow-card-hover hover:border-primary transition-all"
                    aria-label="Következő vélemény">
                    <span class="material-symbols-outlined text-[24px]">chevron_right</span>
                </button>
                <div class="overflow-hidden" id="ti-viewport">
                    <div class="flex" style="gap:2rem" id="ti-track">

                        <!-- T1 -->
                        <div class="ti-card flex flex-col bg-light p-5 sm:p-8 rounded-[16px] border border-border shadow-card hover:shadow-card-hover transition-all"
                            style="flex-shrink:0">
                            <div class="mb-4">
                                <span class="material-symbols-outlined text-primary/10 text-[56px]"
                                    style="font-variation-settings:'FILL' 1">format_quote</span>
                            </div>
                            <div class="flex gap-0.5 mb-4 -mt-2">
                                <span class="text-yellow-400">★</span><span class="text-yellow-400">★</span><span
                                    class="text-yellow-400">★</span><span class="text-yellow-400">★</span><span
                                    class="text-yellow-400">★</span>
                            </div>
                            <p class="text-body italic mb-6 leading-relaxed flex-1">„Rengeteg időt spórol azzal, hogy
                                terméklink alapján magától generál szöveget, képet és automatikusan posztol is. Nagy
                                segítség!"</p>
                            <div class="flex items-center gap-3 mt-auto">
                                <div
                                    class="w-11 h-11 rounded-full bg-primary flex items-center justify-center text-white font-bold text-sm uppercase">
                                    Sz</div>
                                <div>
                                    <p class="font-bold text-dark text-sm">Szabad Mária</p>
                                    <p class="text-xs text-muted">Károlyi-plast webáruház</p>
                                </div>
                            </div>
                        </div>

                        <!-- T2 -->
                        <div class="ti-card flex flex-col bg-light p-5 sm:p-8 rounded-[16px] border border-border shadow-card hover:shadow-card-hover transition-all"
                            style="flex-shrink:0">
                            <div class="mb-4">
                                <span class="material-symbols-outlined text-primary/10 text-[56px]"
                                    style="font-variation-settings:'FILL' 1">format_quote</span>
                            </div>
