---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const locale = 'hu';
const page = 'home';

const title = 'Content Ninja – AI Tartalomgyártás Webshopoknak | Automatikus Posztolás';
const description =
  'A Content Ninja AI-alapú tartalomgyártó eszköz webshopoknak. Automatikusan generál posztokat, képeket és videókat a termékeidből, és publikálja is helyetted. Próbáld ki díjmentesen!';
const keywords =
  'Content Ninja, AI tartalomgyártás, webshop marketing, automatikus posztolás, social media automatizálás, AI influenszer, tartalomnaptár';

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Mi az a Content Ninja?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A Content Ninja egy AI-alapú tartalomgyártó és publikáló platform, amelyet kifejezetten webshopok számára fejlesztettünk. Automatikusan generál social media posztokat, képeket és videókat a termékeidből, majd ezeket Facebookon, Instagramon és LinkedInen közzé is teszi.',
      },
    },
    {
      '@type': 'Question',
      name: 'Mennyibe kerül a Content Ninja előfizetés?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A standard előfizetés havi 24.990 Ft + ÁFA, amely havi 400 megújuló AI kreditet tartalmaz. A 12.495 Ft + ÁFA bemutató bónusz csak az első hónapra szól, utána a fix 24.990 Ft + ÁFA / hó ár érvényes.',
      },
    },
    {
      '@type': 'Question',
      name: 'Kell-e marketing tudás a Content Ninja használatához?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Nem, a Content Ninja pont azoknak készült, akiknek nincs ideje vagy háttértudása a marketing menedzsmenthez. Az AI elvégzi a szakértők munkáját automatikusan.',
      },
    },
  ],
};
---

<BaseLayout locale={locale} page={page} title={title} description={description} keywords={keywords}>
  <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(faqLd)} />

  <Header locale={locale} page={page} />

  <main>
    <!-- ═══════════════════════════════════════
     HERO
═══════════════════════════════════════ -->
    <section id="hero" class="hero-gradient py-10 md:py-28 px-4 md:px-10 overflow-hidden">
        <div class="max-w-[1200px] mx-auto">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

                <!-- Left: szöveg -->
                <div class="flex flex-col gap-5 animate-fade-up">
                    <h1
                        class="text-4xl md:text-[2.85rem] lg:text-5xl font-extrabold leading-[1.08] tracking-[-0.03em] text-dark">
                        Automatizáld be<br /><span class="text-primary">webshopod</span>
                        közösségi média posztolását
                    </h1>

                    <p class="text-lg text-body leading-snug max-w-[520px]">
                        A Content Ninja AI szöveget ír, képet szerkeszt,
                        <strong class="text-dark">videót generál</strong> és posztol is helyetted –
                        a termékeidből, automatikusan.
                    </p>

                    <ul class="space-y-2 text-body">
                        <li class="flex items-start gap-2.5">
                            <span class="material-symbols-outlined text-primary text-[20px] mt-0.5"
                                style="font-variation-settings:'FILL' 1">check_circle</span>
                            <span><strong class="text-dark">Nem kell többé órákat töltened</strong> posztok írásával és
                                képek szerkesztésével</span>
                        </li>
                        <li class="flex items-start gap-2.5">
                            <span class="material-symbols-outlined text-primary text-[20px] mt-0.5"
                                style="font-variation-settings:'FILL' 1">check_circle</span>
                            <span><strong class="text-dark">Folyamatos, profi jelenlét</strong> a social médiában –
                                akkor is, ha nincs rá időd</span>
                        </li>
                        <li class="flex items-start gap-2.5">
                            <span class="material-symbols-outlined text-primary text-[20px] mt-0.5"
                                style="font-variation-settings:'FILL' 1">check_circle</span>
                            <span>Több látogató és vásárló, <strong class="text-dark">kevesebb ráfordított
                                    munkaórával</strong></span>
                        </li>
                    </ul>

                    <div class="flex flex-col sm:flex-row gap-3 pt-1">
                        <a href="/hu/bemutato" class="cta-primary px-7 py-4 text-base">
                            <span class="material-symbols-outlined text-[18px]">calendar_month</span>
                            Díjmentes bemutatót kérek
                        </a>
                        <a href="https://app.getcontentninja.com" target="_blank" class="cta-secondary px-7 py-4 text-base">
                            <span class="material-symbols-outlined text-[18px]">login</span>
                            Belépek az appba
                        </a>
                    </div>

                </div>

                <!-- Right: YouTube embed + social proof -->
                <div class="flex flex-col gap-3 animate-fade-up delay-200">
                    <div
                        class="relative rounded-[20px] overflow-hidden shadow-primary-glow border border-primary/10 bg-dark aspect-video">
                        <iframe id="hero-video" class="w-full h-full" src="https://www.youtube.com/embed/g67df7BUczE"
                            title="Content Ninja – Rendszer bemutató videó" frameborder="0"
                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                            allowfullscreen>
                        </iframe>
                    </div>
                    <p class="text-center text-muted text-xs">▶ Nézd meg, hogyan működik az AI tartalomgyártás a
                        gyakorlatban</p>

                    <!-- Social proof mini -->
                    <div class="flex items-center justify-center gap-3 pt-1">
                        <div class="flex -space-x-2">
                            <div
                                class="w-8 h-8 rounded-full bg-primary flex items-center justify-center text-white text-xs font-bold border-2 border-white">
                                Sz</div>
                            <div
                                class="w-8 h-8 rounded-full bg-primary/70 flex items-center justify-center text-white text-xs font-bold border-2 border-white">
                                L</div>
                            <div
                                class="w-8 h-8 rounded-full bg-primary/50 flex items-center justify-center text-white text-xs font-bold border-2 border-white">
                                ÁK</div>
                        </div>
                        <p class="text-sm text-muted"><span class="font-semibold text-dark">50+ webshop</span> már
                            használja</p>
                    </div>
                </div>
            </div>
        </div>
    </section>


    <!-- ═══════════════════════════════════════
     MEGOLDÁSOK / USE-CASE-EK
═══════════════════════════════════════ -->
    <section id="megoldasok" class="bg-card py-20 md:py-28 px-4 md:px-10">
        <div class="max-w-[1200px] mx-auto">
            <div class="text-center max-w-[700px] mx-auto mb-14">
                <span class="text-primary font-bold text-sm uppercase tracking-widest block mb-3">Megoldások</span>
                <h2 class="text-3xl md:text-4xl font-bold mb-4">Mire használják a Content Ninját?</h2>
                <p class="text-body text-lg">Válaszd ki, mi a te helyzeted – megmutatjuk, hogyan segít a rendszer.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-[900px] mx-auto">

                <!-- Automata posztolás -->
                <a href="/hu/bemutato"
                    class="group bg-light rounded-[16px] border border-border p-8 shadow-card hover:shadow-card-hover transition-all hover:-translate-y-0.5 flex flex-col">
                    <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center text-primary mb-5">
                        <span class="material-symbols-outlined text-[22px]">auto_awesome</span>
                    </div>
                    <h3 class="font-bold text-xl mb-2 text-dark">Automata posztolás</h3>
                    <p class="text-body text-sm leading-relaxed mb-5 flex-1">Az AI a termékeidből szöveget ír, képet és
                        videót készít, majd időzítve ki is posztolja helyetted – Facebookra, Instagramra és LinkedInre.
                        Neked csak jóvá kell hagynod, ha szeretnéd.</p>
                    <span class="text-primary font-bold text-sm inline-flex items-center gap-1">
                        Nézd meg
                        <span class="material-symbols-outlined text-[18px] group-hover:translate-x-0.5 transition-transform">arrow_forward</span>
                    </span>
                </a>

                <!-- Nemzetközi terjeszkedés -->
                <a href="/hu/nemzetkozi"
                    class="group bg-primary/[0.04] rounded-[16px] border-2 border-primary/30 p-8 shadow-card hover:shadow-card-hover transition-all hover:-translate-y-0.5 flex flex-col">
                    <div class="w-12 h-12 bg-primary rounded-full flex items-center justify-center text-white mb-5">
                        <span class="material-symbols-outlined text-[22px]">public</span>
                    </div>
                    <h3 class="font-bold text-xl mb-2 text-dark">Nemzetközi terjeszkedés</h3>
                    <p class="text-body text-sm leading-relaxed mb-5 flex-1">Több országban, több nyelven? Egy tartalomból
                        minden nyelvi verzió, minden ország közösségi fiókja egy naptárban.</p>
                    <span class="text-primary font-bold text-sm inline-flex items-center gap-1">
                        Részletek
                        <span class="material-symbols-outlined text-[18px] group-hover:translate-x-0.5 transition-transform">arrow_forward</span>
                    </span>
                </a>

            </div>
        </div>
    </section>


    <!-- ═══════════════════════════════════════
     HOGYAN MŰKÖDIK
═══════════════════════════════════════ -->
    <section id="hogyan-mukodik" class="bg-light py-20 md:py-28 px-4 md:px-10">
        <div class="max-w-[1200px] mx-auto">
            <div class="text-center mb-14">
                <span class="text-primary font-bold text-sm uppercase tracking-widest block mb-3">Hogyan működik?</span>
                <h2 class="text-3xl md:text-4xl font-bold mb-4">4 lépés a teljes automatizálásig</h2>
                <p class="text-body text-lg">Nincs szükség kreatív ügynökségre vagy marketing szakemberre. Egyszer
                    beállítod, az AI a többit magától intézi.</p>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-8 relative">

                <!-- Step 1 -->
                <div class="bg-card rounded-[16px] border border-border p-5 sm:p-8 shadow-card text-center relative">
                    <div
                        class="w-14 h-14 bg-primary rounded-full flex items-center justify-center text-white text-2xl font-extrabold mx-auto mb-6 shadow-primary-glow">
                        1</div>
                    <h3 class="font-bold text-lg mb-3">Alapbeállítás</h3>
                    <p class="text-body text-sm leading-relaxed">Egyszer megadod a webshopod linkjét
                        és a logódat. Ennyi – a rendszer a többit magától intézi.</p>
                </div>

                <!-- Step 2 -->
                <div class="bg-card rounded-[16px] border border-border p-5 sm:p-8 shadow-card text-center relative">
                    <div
                        class="w-14 h-14 bg-primary rounded-full flex items-center justify-center text-white text-2xl font-extrabold mx-auto mb-6 shadow-primary-glow">
                        2</div>
                    <h3 class="font-bold text-lg mb-3">Ötletet vadászik</h3>
                    <p class="text-body text-sm leading-relaxed">A rendszer magától átnézi a webshopodat, kiválasztja a
                        legrelevánsabb termékeket, és témaötleteket talál ki – neked ezzel semmi dolgod.</p>
                </div>

                <!-- Step 3 -->
                <div class="bg-card rounded-[16px] border border-border p-5 sm:p-8 shadow-card text-center relative">
                    <div
                        class="w-14 h-14 bg-primary rounded-full flex items-center justify-center text-white text-2xl font-extrabold mx-auto mb-6 shadow-primary-glow">
                        3</div>
                    <h3 class="font-bold text-lg mb-3">Posztot generál</h3>
                    <p class="text-body text-sm leading-relaxed">Az AI megírja a posztszöveget, elkészíti a brandazonos
                        kreatív képet, mozgó animációt vagy videót – a márkád stílusában, logóval ellátva.</p>
                </div>

                <!-- Step 4 -->
                <div class="bg-card rounded-[16px] border border-border p-5 sm:p-8 shadow-card text-center">
                    <div
                        class="w-14 h-14 bg-primary rounded-full flex items-center justify-center text-white text-2xl font-extrabold mx-auto mb-6 shadow-primary-glow">
                        4</div>
                    <h3 class="font-bold text-lg mb-3">Önállóan publikál</h3>
                    <p class="text-body text-sm leading-relaxed">A rendszer beütemezi és közzéteszi a tartalmakat
                        Facebookon, Instagramon és LinkedInen. Neked csak jóvá kell hagynod – ha szeretnéd.</p>
                </div>
            </div>

            <div class="text-center mt-10">
                <a href="/hu/bemutato" class="cta-primary px-8 py-4 text-base">
                    Bemutatót kérek – díjmentes
                </a>
            </div>
        </div>
    </section>


    <!-- ═══════════════════════════════════════
     INTEGRÁCIÓK
═══════════════════════════════════════ -->
    <section id="integraciok" class="bg-light py-20 md:py-28 px-4 md:px-10">
        <div class="max-w-[1200px] mx-auto">
            <div class="text-center max-w-[760px] mx-auto mb-12">
                <span class="text-primary font-bold text-sm uppercase tracking-widest block mb-3">Integrációk</span>
                <h2 class="text-3xl md:text-4xl font-bold mb-4">Csatlakoztasd, amid van – posztol, amerre kell</h2>
                <p class="text-body text-lg">A Content Ninja összeköti a webshopodat, a forrásaidat és a közösségi
                    fiókjaidat. Behúzza a termékeidet és a tartalmaidat, legyártja a posztokat és a hírleveleket, majd
                    publikál is – automatikusan.</p>
            </div>

            <!-- Hangsúlyos szemléltető kép: integrációs hub -->
            <div class="relative mb-14 md:mb-16">
                <div class="absolute -inset-4 md:-inset-8 bg-primary/10 blur-3xl rounded-full -z-10"></div>
                <div class="relative rounded-[20px] overflow-hidden border border-primary/10 shadow-primary-glow">
                    <img src="/assets/integraciok-latvanykep.webp"
                        alt="Content Ninja mint központi integrációs hub: webshop, hírlevél és külső források összekötve a közösségi média fiókokkal"
                        loading="lazy" class="w-full h-auto block">
                </div>
            </div>

            <!-- 4 integrációs kategória -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

                <!-- Közösségi média -->
                <div class="bg-card rounded-[16px] border border-border p-7 shadow-card hover:shadow-card-hover transition-all hover:-translate-y-0.5 flex flex-col">
                    <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center text-primary mb-5">
                        <span class="material-symbols-outlined text-[22px]">share</span>
                    </div>
                    <h3 class="font-bold text-lg mb-1.5 text-dark">Közösségi média</h3>
                    <p class="text-body text-sm leading-relaxed mb-5 flex-1">Automatikus posztolás közvetlenül a kész
                        fiókjaidba.</p>
                    <div class="flex flex-wrap gap-2">
                        <span class="inline-flex items-center gap-1.5 bg-light border border-border rounded-lg px-2.5 py-1.5 text-sm font-semibold text-dark shadow-card">
                            <svg width="20" height="20" viewBox="0 0 24 24" aria-hidden="true"><rect width="24" height="24" rx="6" fill="#1877F2"/><path d="M14.9 12.5l.35-2.3h-2.2V8.7c0-.63.31-1.24 1.3-1.24h1V5.5s-.9-.15-1.77-.15c-1.8 0-2.98 1.1-2.98 3.07v1.78H8.6v2.3h1.99V18h2.45v-5.5h1.86z" fill="#fff"/></svg>
                            Facebook
                        </span>
                        <span class="inline-flex items-center gap-1.5 bg-light border border-border rounded-lg px-2.5 py-1.5 text-sm font-semibold text-dark shadow-card">
                            <svg width="20" height="20" viewBox="0 0 24 24" aria-hidden="true"><defs><linearGradient id="igGradInt" x1="2" y1="22" x2="22" y2="2" gradientUnits="userSpaceOnUse"><stop stop-color="#FEDA75"/><stop offset=".35" stop-color="#FA7E1E"/><stop offset=".6" stop-color="#D62976"/><stop offset="1" stop-color="#962FBF"/></linearGradient></defs><rect width="24" height="24" rx="6" fill="url(#igGradInt)"/><rect x="6" y="6" width="12" height="12" rx="4" fill="none" stroke="#fff" stroke-width="1.5"/><circle cx="12" cy="12" r="2.8" fill="none" stroke="#fff" stroke-width="1.5"/><circle cx="16.2" cy="7.8" r="1" fill="#fff"/></svg>
                            Instagram
                        </span>
                    </div>
                </div>

                <!-- Webáruház -->
                <div class="bg-card rounded-[16px] border border-border p-7 shadow-card hover:shadow-card-hover transition-all hover:-translate-y-0.5 flex flex-col">
                    <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center text-primary mb-5">
                        <span class="material-symbols-outlined text-[22px]">storefront</span>
                    </div>
                    <h3 class="font-bold text-lg mb-1.5 text-dark">Webáruház</h3>
                    <p class="text-body text-sm leading-relaxed mb-5 flex-1">Behúzza a termékeidet – Unas integrációval
                        vagy bármilyen webshopból sitemap alapján.</p>
                    <div class="flex flex-wrap gap-2">
                        <span class="inline-flex items-center gap-1.5 bg-light border border-border rounded-lg px-2.5 py-1.5 text-sm font-semibold text-dark shadow-card">
                            <span class="w-5 h-5 rounded-md flex items-center justify-center text-white text-[10px] font-extrabold" style="background:#E94E1B">U</span>
                            Unas
                        </span>
                        <span class="inline-flex items-center gap-1.5 bg-light border border-border rounded-lg px-2.5 py-1.5 text-sm font-semibold text-dark shadow-card">
                            <span class="material-symbols-outlined text-primary text-[18px]">account_tree</span>
                            Sitemap
                        </span>
                    </div>
                </div>

                <!-- Hírlevél -->
                <div class="bg-card rounded-[16px] border border-border p-7 shadow-card hover:shadow-card-hover transition-all hover:-translate-y-0.5 flex flex-col">
                    <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center text-primary mb-5">
                        <span class="material-symbols-outlined text-[22px]">mail</span>
                    </div>
                    <h3 class="font-bold text-lg mb-1.5 text-dark">Hírlevél</h3>
                    <p class="text-body text-sm leading-relaxed mb-5 flex-1">A legyártott hírleveleket egyenesen a
                        levelezőrendszeredbe küldi.</p>
                    <div class="flex flex-wrap gap-2">
                        <span class="inline-flex items-center gap-1.5 bg-light border border-border rounded-lg px-2.5 py-1.5 text-sm font-semibold text-dark shadow-card">
                            <span class="w-5 h-5 rounded-md flex items-center justify-center text-white text-[10px] font-extrabold" style="background:#1B6DC1">SA</span>
                            SalesAutopilot
                        </span>
                        <span class="inline-flex items-center gap-1.5 bg-light border border-border rounded-lg px-2.5 py-1.5 text-sm font-semibold text-dark shadow-card">
                            <span class="w-5 h-5 rounded-md flex items-center justify-center text-white text-[10px] font-extrabold" style="background:#09C269">ML</span>
                            MailerLite
                        </span>
                    </div>
                </div>

                <!-- Külsős oldalak -->
                <div class="bg-card rounded-[16px] border border-border p-7 shadow-card hover:shadow-card-hover transition-all hover:-translate-y-0.5 flex flex-col">
                    <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center text-primary mb-5">
                        <span class="material-symbols-outlined text-[22px]">rss_feed</span>
                    </div>
                    <h3 class="font-bold text-lg mb-1.5 text-dark">Külsős oldalak</h3>
                    <p class="text-body text-sm leading-relaxed mb-5 flex-1">Kövess bármilyen forrást, és a friss
                        tartalmakból automatikusan posztot készít.</p>
                    <div class="flex flex-wrap gap-2">
                        <span class="inline-flex items-center gap-1.5 bg-light border border-border rounded-lg px-2.5 py-1.5 text-sm font-semibold text-dark shadow-card">
                            <svg width="20" height="20" viewBox="0 0 24 24" aria-hidden="true"><rect width="24" height="24" rx="6" fill="#F26522"/><circle cx="7.5" cy="16.5" r="1.7" fill="#fff"/><path d="M6 11.2a6.8 6.8 0 0 1 6.8 6.8" fill="none" stroke="#fff" stroke-width="1.8" stroke-linecap="round"/><path d="M6 7.2A11.6 11.6 0 0 1 17.6 18.8" fill="none" stroke="#fff" stroke-width="1.8" stroke-linecap="round"/></svg>
                            RSS
                        </span>
                    </div>
                </div>

            </div>

            <!-- Bármilyen link kiemelés -->
            <div class="mt-8 rounded-[16px] border-2 border-primary/25 bg-primary/[0.04] p-6 md:p-7 flex flex-col sm:flex-row sm:items-center gap-4 md:gap-6">
                <div class="w-12 h-12 bg-primary rounded-full flex items-center justify-center text-white shrink-0 shadow-primary-glow">
                    <span class="material-symbols-outlined text-[24px]">link</span>
                </div>
                <div class="flex-1">
                    <h3 class="font-bold text-lg text-dark mb-1">+ Bármilyen külső vagy belső linkből tartalmat gyárt</h3>
                    <p class="text-body text-sm leading-relaxed">Nem csak a beépített integrációk. Adj meg bármilyen
                        terméklinket, blogcikket vagy külső oldalt – a rendszer kiolvassa a tartalmát, és kész posztot
                        készít belőle.</p>
                </div>
            </div>

            <div class="text-center mt-10">
                <a href="/hu/bemutato" class="cta-primary px-8 py-4 text-base">
                    Bemutatót kérek – díjmentes
                </a>
            </div>
        </div>
    </section>


    <!-- ═══════════════════════════════════════
     VÉLEMÉNYEK
═══════════════════════════════════════ -->
    <section id="velemenyek" class="bg-card py-20 md:py-28 px-4 md:px-10">
        <div class="max-w-[1200px] mx-auto">
            <div class="text-center max-w-[700px] mx-auto mb-14">
                <span class="text-primary font-bold text-sm uppercase tracking-widest block mb-3">Vélemények</span>
                <h2 class="text-3xl md:text-4xl font-bold mb-4">Mit mondanak rólunk ügyfeleink?</h2>
            </div>

            <div class="relative">
                <button type="button" id="ti-prev"
                    class="hidden sm:flex absolute left-3 top-1/2 -translate-y-1/2 xl:-left-6 z-10 w-11 h-11 items-center justify-center rounded-full bg-card border border-border text-primary shadow-card hover:shadow-card-hover hover:border-primary transition-all"
