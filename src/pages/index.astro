---
// Gyökér (/) – nyelv-detektáló átirányító.
// Böngésző nyelve alapján /hu/ vagy /en/, alapértelmezett fallback: /hu/.
// Nincs saját tartalma, ne is indexelje a kereső.
---

<!doctype html>
<html lang="hu">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Content Ninja</title>
    <link rel="alternate" hreflang="hu" href="https://getcontentninja.com/hu/" />
    <link rel="alternate" hreflang="en" href="https://getcontentninja.com/en/" />
    <link rel="alternate" hreflang="x-default" href="https://getcontentninja.com/hu/" />
    <script is:inline>
      (function () {
        var lang = (navigator.language || navigator.userLanguage || 'hu').toLowerCase();
        var target = lang.indexOf('hu') === 0 ? '/hu/' : '/en/';
        window.location.replace(target);
      })();
    </script>
    <noscript>
      <meta http-equiv="refresh" content="0; url=/hu/" />
    </noscript>
  </head>
  <body>
    <p style="font-family: sans-serif; text-align: center; margin-top: 3rem;">
      <a href="/hu/">Tovább magyarul →</a> &nbsp;·&nbsp; <a href="/en/">Continue in English →</a>
    </p>
  </body>
</html>
