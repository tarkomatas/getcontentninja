---
import { switchTarget, type Locale, type PageKey } from '../i18n/routes';
import { t } from '../i18n/ui';

interface Props {
  locale: Locale;
  page: PageKey;
  /** Extra osztályok az anchor elemen. */
  class?: string;
}

const { locale, page, class: className = '' } = Astro.props;
const target = switchTarget(page, locale);
const ui = t(locale);
---

<a
  href={target.path}
  hreflang={target.locale}
  aria-label={ui.langSwitch.aria}
  title={ui.langSwitch.aria}
  class:list={[
    'inline-flex items-center hover:opacity-80 transition-opacity',
    className,
  ]}
>
  <img
    src={`/assets/flags/${ui.langSwitch.flag}.svg`}
    alt={ui.langSwitch.label}
    width="26"
    height="18"
    class="h-[18px] w-auto rounded-[3px] ring-1 ring-black/10 shadow-sm"
  />
</a>
