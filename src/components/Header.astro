---
import { homeFor, pathFor, type Locale, type PageKey } from '../i18n/routes';
import { t } from '../i18n/ui';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  locale: Locale;
  page: PageKey;
}

const { locale, page } = Astro.props;
const ui = t(locale);
const home = homeFor(locale);
const demo = pathFor('demo', locale);
const bookDemo = pathFor('bookDemo', locale);
const international = pathFor('international', locale);
const unas = pathFor('unas', locale);
const newsletter = pathFor('newsletter', locale);
const APP_URL = 'https://app.getcontentninja.com';

// Megj.: nincs külön "funkciók" szekció az oldalon, ezért a korábban árva
// (#funkciok) nav-elemet elhagytuk – csak létező horgonyokra mutatunk.
// A "Megoldások" lenyíló menü önálló kampányoldalakra mutat (nem horgonyokra):
// az "Automata posztolás" a posztolás megoldás-oldalra, a "Nemzetközi
// terjeszkedés" a saját kampányoldalára. A fejléc elsődleges "Bemutatót kérek"
// CTA-ja ezzel szemben az általános demo oldalra (bookDemo) visz.
const solutionItems = [
  {
    href: demo,
    icon: 'auto_awesome',
    label: ui.nav.autoPosting,
    desc: ui.nav.autoPostingDesc,
  },
  {
    href: international,
    icon: 'public',
    label: ui.nav.internationalExpansion,
    desc: ui.nav.internationalExpansionDesc,
  },
  {
    href: unas,
    icon: 'storefront',
    label: ui.nav.unasIntegration,
    desc: ui.nav.unasIntegrationDesc,
  },
  {
    href: newsletter,
    icon: 'mail',
    label: ui.nav.newsletter,
    desc: ui.nav.newsletterDesc,
  },
];
const navItems = [
  { href: `${home}#hogyan-mukodik`, label: ui.nav.how },
  { href: `${home}#velemenyek`, label: ui.nav.testimonials },
  { href: `${home}#arazas`, label: ui.nav.pricing },
];
---

<header id="top" class="bg-card border-b border-border sticky top-0 z-50 shadow-card">
  <div class="max-w-[1200px] mx-auto px-4 md:px-10 py-3 flex items-center justify-between gap-6">
    <!-- Logo -->
    <a href={home} class="shrink-0">
      <img src="/assets/logo.webp" alt={ui.logoAlt} class="h-12 md:h-14 w-auto object-contain" />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-8 lp-hide" aria-label={ui.nav.aria}>
      <!-- Megoldások lenyíló (hoverre + fókuszra nyílik, a pt-2 híd tartja a hovert) -->
      <div class="relative group">
        <button
          type="button"
          class="nav-link text-sm flex items-center gap-1 cursor-pointer"
          aria-haspopup="true"
        >
          {ui.nav.solutions}
          <span class="material-symbols-outlined text-[18px] transition-transform duration-150 group-hover:rotate-180">expand_more</span>
        </button>
        <div class="absolute left-0 top-full pt-3 opacity-0 invisible translate-y-1 group-hover:opacity-100 group-hover:visible group-hover:translate-y-0 group-focus-within:opacity-100 group-focus-within:visible group-focus-within:translate-y-0 transition-all duration-150 z-50">
          <div class="min-w-[280px] bg-card border border-border rounded-[14px] shadow-card-hover p-2">
            {solutionItems.map((item) => (
              <a href={item.href} class="flex items-start gap-3 px-3 py-2.5 rounded-[10px] hover:bg-light transition-colors group/item">
                <span class="material-symbols-outlined text-primary text-[22px] mt-0.5">{item.icon}</span>
                <span class="min-w-0">
                  <span class="block text-sm font-semibold text-dark group-hover/item:text-primary transition-colors">{item.label}</span>
                  <span class="block text-xs text-body mt-0.5 leading-snug">{item.desc}</span>
                </span>
              </a>
            ))}
          </div>
        </div>
      </div>
      {navItems.map((item) => (
        <a href={item.href} class="nav-link text-sm">{item.label}</a>
      ))}
    </nav>

    <!-- CTAs + language + hamburger -->
    <div class="flex items-center gap-3 shrink-0">
      <LanguageSwitcher locale={locale} page={page} class="!hidden md:!inline-flex lp-hide" />
      <a href={APP_URL} target="_blank" class="cta-secondary !hidden md:!inline-flex items-center gap-2 px-4 py-2 text-sm lp-hide">
        <span class="material-symbols-outlined text-[16px]">login</span>
        {ui.cta.login}
      </a>
      <a href={bookDemo} class="cta-primary !hidden md:!inline-flex items-center gap-2 px-4 py-2 text-sm lp-show">
        <span class="material-symbols-outlined text-[16px]">calendar_month</span>
        {ui.cta.demo}
      </a>
      <!-- Hamburger (mobile only) -->
      <button
        id="mobile-menu-btn"
        class="md:hidden lp-hide flex items-center justify-center w-10 h-10 rounded-[10px] border border-border text-dark hover:bg-light transition-colors"
        aria-label={ui.nav.menuAria}
      >
        <span id="hamburger-icon" class="material-symbols-outlined text-[22px]">menu</span>
      </button>
    </div>
  </div>

  <!-- Mobile nav dropdown -->
  <div id="mobile-menu" class="hidden md:hidden lp-hide border-t border-border bg-card px-4 pb-4">
    <nav class="flex flex-col gap-1 pt-3" aria-label={ui.nav.mobileAria}>
      <!-- Megoldások szekció -->
      <span class="px-3 pt-1 pb-1 text-xs font-semibold uppercase tracking-wide text-body/70">{ui.nav.solutions}</span>
      {solutionItems.map((item) => (
        <a href={item.href} class="mobile-nav-link flex items-center gap-3 text-sm px-3 py-2.5 rounded-[8px] hover:bg-light">
          <span class="material-symbols-outlined text-primary text-[20px]">{item.icon}</span>
          <span class="font-medium text-dark">{item.label}</span>
        </a>
      ))}
      <div class="border-t border-border my-2"></div>
      {navItems.map((item) => (
        <a href={item.href} class="mobile-nav-link nav-link text-sm px-3 py-2.5 rounded-[8px] hover:bg-light">
          {item.label}
        </a>
      ))}
    </nav>
    <div class="flex flex-col gap-2 mt-4 pt-4 border-t border-border">
      <LanguageSwitcher locale={locale} page={page} class="justify-center px-4 py-2.5 rounded-[8px] hover:bg-light" />
      <a href={APP_URL} target="_blank" class="cta-secondary flex items-center justify-center gap-2 px-4 py-2.5 text-sm">
        <span class="material-symbols-outlined text-[16px]">login</span>
        {ui.cta.loginApp}
      </a>
      <a href={bookDemo} class="cta-primary flex items-center justify-center gap-2 px-4 py-2.5 text-sm">
        <span class="material-symbols-outlined text-[16px]">calendar_month</span>
        {ui.cta.demo}
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const icon = document.getElementById('hamburger-icon');

  if (btn && menu && icon) {
    btn.addEventListener('click', function () {
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden', isOpen);
      icon.textContent = isOpen ? 'menu' : 'close';
    });

    document.querySelectorAll('.mobile-nav-link').forEach(function (link) {
      link.addEventListener('click', function () {
        menu.classList.add('hidden');
        icon.textContent = 'menu';
      });
    });
  }
</script>
