# Google Gemini image generation (Nano Banana / Nano Banana Pro)
# Get a key at https://aistudio.google.com/apikey — then copy this file to .env and fill it in.
# .env is gitignored and never deployed.
GEMINI_API_KEY=

# Optional: override the default image model id.
# Nano Banana Pro ("2"): gemini-3-pro-image-preview
# Nano Banana (fast/cheap): gemini-2.5-flash-image
# GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview
